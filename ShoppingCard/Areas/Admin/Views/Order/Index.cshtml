@model IEnumerable<OrderModel>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Danh sách đơn hàng</h2>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Phương thức</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái đơn</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-dark">@item.OrderCode</span></td>
                            <td>@item.CreateDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="fw-bold">@item.UserName</div>
                                @if (!string.IsNullOrEmpty(item.CouponCode)) {
                                    <div class="small text-success"><i class="fas fa-ticket-alt"></i> @item.CouponCode</div>
                                }
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(item.PaymentMethod) || item.PaymentMethod == "COD")
                                {
                                    <span class="status-badge badge-cod">Tiền mặt (COD)</span>
                                }
                                else
                                {
                                    string[] split = item.PaymentMethod.Split(" ");
                                    string method = split[0];
                                    string transId = split.Length > 1 ? split[1] : "";

                                    @if (method == "MOMO") {
                                        <a asp-action="PaymentMomoInfo" asp-route-orderid="@transId" class="status-badge badge-online text-pink" style="border-color: #d82d8b; color: #d82d8b;">
                                            <i class="fas fa-wallet"></i> MOMO @transId
                                        </a>
                                    } else if (method == "VnPay") {
                                        <a asp-action="PaymentVnpayInfo" asp-route-orderid="@transId" class="status-badge badge-online">
                                            <i class="fas fa-university"></i> VNPAY @transId
                                        </a>
                                    } else {
                                        <span class="status-badge badge-online">@item.PaymentMethod</span>
                                    }
                                }
                            </td>
                            <td>
                                @{
                                    var payBadge = item.PaymentStatus switch
                                    {
                                        PaymentStatus.Paid => ("badge-processed", "fas fa-check-circle", "Đã thanh toán"),
                                        PaymentStatus.Pending => ("badge-new", "fas fa-hourglass-half", "Chờ thanh toán"),
                                        PaymentStatus.Unpaid => ("badge-cod", "fas fa-hand-holding-usd", "Chưa thanh toán"),
                                        PaymentStatus.Failed => ("badge-cancelled", "fas fa-times-circle", "Thanh toán thất bại"),
                                        PaymentStatus.Refunded => ("badge-new", "fas fa-undo", "Đã hoàn tiền"),
                                        _ => ("badge-cod", "fas fa-question", "Không rõ")
                                    };
                                }
                                <span class="status-badge @payBadge.Item1">
                                    <i class="@payBadge.Item2 me-1"></i>@payBadge.Item3
                                </span>
                            </td>
                            <td>
                                @{
                                    // Since Failed always means Cancelled now, just use Status directly
                                    var statusClass = item.Status switch
                                    {
                                        OrderStatus.New => "badge-new",
                                        OrderStatus.Confirmed => "badge-processed",
                                        OrderStatus.Processing => "badge-processed",
                                        OrderStatus.Shipping => "badge-processed",
                                        OrderStatus.Completed => "badge-processed",
                                        OrderStatus.Cancelled => "badge-cancelled",
                                        _ => "badge-cod"
                                    };
                                    if (item.PaymentStatus == PaymentStatus.Pending) statusClass = "badge-new";
                                }
                                <span class="status-badge @statusClass">
                                    @item.DisplayStatus
                                </span>
                            </td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="ViewOrder" asp-route-odercode="@item.OrderCode" class="btn-admin-view">
                                        <i class="fas fa-eye"></i> Chi tiết
                                    </a>
                                    <form asp-action="DeleteOrder" method="post" onsubmit="return confirm('Xóa đơn hàng này?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ordercode" value="@item.OrderCode" />
                                        <button type="submit" class="btn-admin-delete" style="border:none; padding:7px 12px;">
                                            <i class="fas fa-trash"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
