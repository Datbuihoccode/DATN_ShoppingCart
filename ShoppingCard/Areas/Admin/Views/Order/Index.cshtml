@model IEnumerable<OrderModel>
@{
    ViewData["Title"] = "Đơn hàng";
    Paginate pager = new Paginate();

    int pageNo = 0;

    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}
<h3>Danh sách đơn hàng</h3>
<a asp-action="Create" asp-controller="Category">Add Category</a>
<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Mã đơn hàng</th>
            <th scope="col">Người đặt</th>
            <th scope="col">Mã giảm giá</th>
            <th scope="col">Phương thức thanh toán</th>
            <th scope="col">Trạng thái</th>
            <th scope="col">Ngày tạo</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderCode</td>
                <td>@item.UserName</td>
                <td>@(string.IsNullOrWhiteSpace(item.CouponCode) ? "-" : item.CouponCode)</td>
                <td>
                    @if (string.IsNullOrWhiteSpace(item.PaymentMethod) || item.PaymentMethod == "COD")
                    {
                        <span class="text text-primary">COD</span>
                    }
                    else
                    {
                        string text = item.PaymentMethod;
                        string[] split = text.Split(" ");
                        string text_split = split[0];

                        @if (text_split == "MOMO")
                        {
                            string number_split = split.Length > 1 ? split[1] : text;
                            <a asp-action="PaymentMomoInfo" asp-route-orderid="@number_split" asp-controller="Order" asp-area="Admin">
                                <span class="text text-success">@number_split</span>
                            </a>
                        }
                        else if (text_split == "VnPay")
                        {
                            string number_split = split.Length > 1 ? split[1] : text;
                            <a asp-action="PaymentVnpayInfo" asp-route-orderid="@number_split" asp-controller="Order" asp-area="Admin">
                                <span class="text text-success">@number_split</span>
                            </a>
                        }
                        else
                        {
                            <span class="text text-primary">@text</span>
                        }
                    }
                </td>
                <td>
                    @if (item.Status == 1)
                    {
                        <span class="text text-success">Đơn hàng mới</span>
                    }
                    else if (item.Status == 3)
                    {
                        <span class="text text-danger">Đã hủy</span>
                    }
                    else
                    {
                        <span class="text text-primary">Đã xử lý</span>
                    }
                </td>
                <td>@item.CreateDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                <td>
                    <a asp-action="ViewOrder" class="btn btn-warning btn-sm" asp-controller="Order" asp-route-odercode="@item.OrderCode">Xem đơn hàng</a>
                    <form asp-action="DeleteOrder"
                          asp-controller="Order"
                          asp-area="Admin"
                          method="post"
                          style="display:inline;"
                          onsubmit="return confirm('Xác nhận xóa đơn hàng?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ordercode" value="@item.OrderCode" />
                        <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
<partial name="_paging" model="@pager" />
