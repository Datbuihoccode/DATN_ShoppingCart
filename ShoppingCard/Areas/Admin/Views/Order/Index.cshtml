@model IEnumerable<OrderModel>
@{
    ViewData["Title"] = "Đơn hàng";
    Paginate pager = new Paginate();

    int pageNo = 0;

    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.CurrentPage;
    }
}
<h3>List Order </h3>
<a asp-action="Create" asp-controller="Category">Add Category</a>
<table class="table" id="myTable">
    <thead>
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Order Code</th>
            <th scope="col">UserName</th>
            <th scope="col">Order Status</th>
            <th scope="col">Create Date</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderCode</td>
                <td>@item.UserName</td>
                 
                <td>
                    @if (@item.Status == 1)
                    {
                        <span class="text text-success"> Đơn hàng mới</span>
                    }
                    else
                    {
                        <span class="text text-danger">Đơn hàng đã giao </span>
                    }
                </td>
                <td>@item.CreateDate.ToString("dd/MM/yyyy HH:mm:ss")</td>

                <td>
                    <a asp-action="ViewOrder" class="btn btn-warning btn-sm" asp-controller="Order" asp-route-odercode="@item.OrderCode">View Order </a>
                    <a asp-action="Delete" class="btn btn-danger btn-sm confirmDeletion" asp-controller="Order" asp-route-Id="@item.Id">Delete</a>
                </td>
            </tr>
        }

    </tbody>
</table>
<partial name="_paging" model="@pager" />
