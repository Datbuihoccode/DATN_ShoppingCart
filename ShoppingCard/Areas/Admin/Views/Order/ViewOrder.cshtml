@model IEnumerable<OrderDetailsModel>
@{
    ViewData["Title"] = "Đơn hàng";

    var details = Model?.ToList() ?? new List<OrderDetailsModel>();
    var order = ViewBag.Order as OrderModel;
    var orderCode = Convert.ToString(ViewBag.OrderCode) ?? details.FirstOrDefault()?.OrderCode ?? string.Empty;
    var couponText = Convert.ToString(ViewBag.CouponCode);
    var couponCode = string.IsNullOrWhiteSpace(couponText) ? "-" : couponText;
    var currentStatus = Convert.ToInt32(ViewBag.Status ?? ViewBag.OrderStatus ?? 1);
    var selectedStatus = currentStatus == 0 ? 2 : currentStatus;
    decimal subtotalAmount = details.Sum(x => x.Price * x.Quantity);
    decimal discountAmount = order?.DiscountAmount ?? 0m;
    if (discountAmount < 0m) { discountAmount = 0m; }
    if (discountAmount > subtotalAmount) { discountAmount = subtotalAmount; }
    decimal totalAmount = subtotalAmount - discountAmount;
}

<h3>Chi tiết đơn hàng</h3>
<input type="hidden" value="@orderCode" class="getId" />

<div class="row" style="margin-bottom: 12px;">
    <div class="col-sm-6">
        <strong>Mã đơn:</strong> @orderCode
    </div>
    <div class="col-sm-6 text-right">
        <strong>Coupon:</strong> @couponCode
    </div>
</div>

<table class="table table-striped table-bordered" id="OrderDetails">
    <thead>
        <tr>
            <th style="width: 70px;">#</th>
            <th>Sản phẩm</th>
            <th style="width: 160px;">Giá</th>
            <th style="width: 100px;">Số lượng</th>
            <th style="width: 180px;">Tạm tính</th>
        </tr>
    </thead>
    <tbody>
        @if (details.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center">Không có chi tiết đơn hàng.</td>
            </tr>
        }
        else
        {
            for (var i = 0; i < details.Count; i++)
            {
                var item = details[i];
                var lineSubtotal = item.Price * item.Quantity;
                <tr>
                    <td>@(i + 1)</td>
                    <td>@(item.Product?.Name ?? "Sản phẩm")</td>
                    <td>@item.Price.ToString("#,## VND")</td>
                    <td>@item.Quantity</td>
                    <td>@lineSubtotal.ToString("#,## VND")</td>
                </tr>
            }
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="4" class="text-right">Tạm tính</th>
            <th>@subtotalAmount.ToString("#,## VND")</th>
        </tr>
        <tr>
            <th colspan="4" class="text-right">Giảm giá</th>
            <th>-@discountAmount.ToString("#,## VND")</th>
        </tr>
        <tr>
            <th colspan="4" class="text-right">Tổng thanh toán</th>
            <th>@totalAmount.ToString("#,## VND")</th>
        </tr>
    </tfoot>
</table>

<div class="row" style="margin-top: 16px;">
    <div class="col-sm-4 col-sm-offset-8">
        <label for="order-status">Trạng thái đơn hàng</label>
        @if (currentStatus != 3)
        {
            <select id="order-status" class="form-control select-update-order">
                <option value="1" selected="@(selectedStatus == 1 ? "selected" : null)">Đơn hàng mới</option>
                <option value="2" selected="@(selectedStatus == 2 ? "selected" : null)">Đã xử lý</option>
            </select>
        }
        else
        {
            <p class="text-danger" style="margin-top: 8px;">Đơn hàng đã hủy, không thể cập nhật trạng thái.</p>
        }
    </div>
</div>

@section Scripts {
    <script>
        new DataTable('#OrderDetails', {
            layout: {
                topStart: {
                    buttons: ['pdf', 'print']
                }
            }
        });
    </script>

    <script>
        $(document).ready(function () {
            $('.select-update-order').change(function () {
                var status = $(this).val();
                var ordercode = $('.getId').val();

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("UpdateOrder")",
                    data: { status: status, ordercode: ordercode },
                    success: function (result) {
                        if (result.success) {
                            Swal.fire("Cập nhật trạng thái đơn hàng thành công!");
                        } else {
                            Swal.fire("Cập nhật trạng thái đơn hàng thất bại! " + result.message);
                        }
                    },
                    error: function () {
                        Swal.fire("Có lỗi xảy ra khi cập nhật trạng thái đơn hàng.");
                    }
                });
            });
        });
    </script>
}
