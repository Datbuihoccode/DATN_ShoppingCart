@model IEnumerable<OrderDetailsModel>
@{
    ViewData["Title"] = "Đơn hàng";
    decimal total = 0;
    decimal subtotal = 0;
}

<!DOCTYPE html>

<html>
    <head>
        <meta name="viewport" content="width=device-width"/>
        <title>Order Details</title>
    </head>
    
    <body>
    <h3>Order Details</h3>
    <table class="table" id="OrderDetails">
        <thead>
            <tr>
                <th>ID</th>
                <th scope="col">Order Code</th>
                <th scope="col">UserName</th>
                <th scope="col">Product Name</th>
                <th scope="col">Product Price</th>
                <th scope="col">Quantity</th>
                <th scope="col">Subtotal</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                subtotal = item.Quantity * item.Price;// tính tổng tiền của từng sản phẩm
                total += subtotal;
                <tr>
                    <input type="hidden" asp-for="@item.OrderCode" class="getId"/>
                    <td>@item.Id</td>
                    <td>@item.OrderCode</td>
                    <td>@item.UserName</td>
                    <td>@item.Product.Name</td>
                    <td>@item.Price.ToString("#,## VNĐ")</td>
                    <td>@item.Quantity</td>
                    <td>@subtotal.ToString("#,## VNĐ")</td>
                </tr>
            }
            <tr>
                <td> Total: </td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td>@total.ToString("C")</td>
                <td>
                    <select class="form-control select-update-order">
                        <option value="1">Đơn hàng mới</option>
                        <option value="0">Đã xử lý</option>
                    </select>
                </td>
            </tr>

        </tbody>
    </table>

    </body>
</html>

@section Scripts{
    <script> 
        new DataTable('#OrderDetails', {
            layout: {
                topStart: {
                    buttons: ['pdf', 'print']
                }
            }
        });
    </script>   

    <script>
        $(document).ready(function () {
            $('.select-update-order').change(function () {
                var status = $(this).val();
                var ordercode = $('.getId').val();
                // alert(status);
                // alert(ordercode);

                $.ajax
                ({
                    type: "POST",
                    url: "@Url.Action("UpdateOrder" )",
                    data: { status: status,  ordercode: ordercode },
                    success: function (result)
                    {
                        if (result.success) {
                            Swal.fire("Cập nhật trạng thái đơn hàng thành công!");
                        } 
                        else { 
                            Swal.fire("Cập nhật trạng thái đơn hàng thất bại! "+ result.message);
                        }
                    }
                });
            });
        });
    </script>
}




