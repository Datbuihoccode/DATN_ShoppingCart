@model IEnumerable<OrderDetailsModel>
@{
    ViewData["Title"] = "Đơn hàng";

    var details = Model?.ToList() ?? new List<OrderDetailsModel>();
    var order = ViewBag.Order as OrderModel;
    var orderCode = Convert.ToString(ViewBag.OrderCode) ?? details.FirstOrDefault()?.OrderCode ?? string.Empty;
    var couponText = Convert.ToString(ViewBag.CouponCode);
    var couponCode = string.IsNullOrWhiteSpace(couponText) ? "-" : couponText;
    decimal subtotalAmount = details.Sum(x => x.Price * x.Quantity);
    decimal discountAmount = order?.DiscountAmount ?? 0m;
    if (discountAmount < 0m) { discountAmount = 0m; }
    if (discountAmount > subtotalAmount) { discountAmount = subtotalAmount; }
    decimal totalAmount = subtotalAmount - discountAmount;
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Chi tiết đơn hàng <small class="text-muted" style="font-size: 0.7em; font-weight: normal;">#@orderCode</small></h2>
    <div class="actions-group">
        <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<input type="hidden" value="@orderCode" class="getId" />

<div class="row g-4">
    @* Left: Order items *@
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <span class="admin-card-title"><i class="fas fa-shopping-cart me-2"></i>Sản phẩm trong đơn</span>
                <span class="badge bg-light text-dark border" style="font-size: 15px; padding: 6px 12px; letter-spacing: 0.5px; font-family: 'Segoe UI Mono', monospace;">Mã đơn: @orderCode</span>
            </div>
            <div class="admin-card-body p-0">
                <div class="table-responsive">
                    <table class="admin-table" id="OrderDetails">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Sản phẩm</th>
                                <th style="width: 140px;">Giá</th>
                                <th style="width: 100px;">SL</th>
                                <th style="width: 150px; text-align: right;">Tạm tính</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (details.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">Không có chi tiết đơn hàng.</td>
                                </tr>
                            }
                            else
                            {
                                for (var i = 0; i < details.Count; i++)
                                {
                                    var item = details[i];
                                    var lineSubtotal = item.Price * item.Quantity;
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td class="fw-bold">@(item.Product?.Name ?? "Sản phẩm")</td>
                                        <td>@item.Price.ToString("#,##0") đ</td>
                                        <td>@item.Quantity</td>
                                        <td style="text-align: right;" class="fw-bold">@lineSubtotal.ToString("#,##0") đ</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="admin-table-footer">
                            <tr>
                                <th colspan="4" style="text-align: right;">Tổng cộng sản phẩm</th>
                                <th style="text-align: right;">@subtotalAmount.ToString("#,##0") đ</th>
                            </tr>
                            <tr>
                                <th colspan="4" style="text-align: right; color: #16a34a;">Mã giảm giá (@couponCode)</th>
                                <th style="text-align: right; color: #16a34a;">-@discountAmount.ToString("#,##0") đ</th>
                            </tr>
                            <tr style="border-top: 1px solid #ddd;">
                                <th colspan="4" style="text-align: right; font-size: 16px;">TỔNG THANH TOÁN</th>
                                <th style="text-align: right; font-size: 16px; color: var(--admin-accent);">@totalAmount.ToString("#,##0") đ</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* Right: Sidebar *@
    <div class="col-lg-4">

        @* Customer Info Card *@
        <div class="admin-card mb-3">
            <div class="admin-card-header py-2">
                <span class="admin-card-title" style="font-size: 13px;">
                    <i class="fas fa-user me-2"></i>Thông tin khách hàng
                </span>
            </div>
            <div class="admin-card-body py-2">
                <div class="d-flex flex-column gap-1" style="font-size: 13px;">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Email:</span>
                        <span class="fw-bold text-truncate ms-2" style="max-width: 200px;">@(order?.UserName ?? "-")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Tên tài khoản:</span>
                        <span class="fw-bold ms-2">@(ViewBag.CustomerName ?? "-")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Số điện thoại:</span>
                        <span class="fw-bold ms-2">
                            @if (!string.IsNullOrWhiteSpace(order?.ShippingPhone))
                            {
                                <a href="tel:@order.ShippingPhone" class="text-decoration-none">@order.ShippingPhone</a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Chưa cập nhật</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* Order Status + Payment Status — compact combined card *@
        <div class="admin-card mb-3">
            <div class="admin-card-header py-2">
                <span class="admin-card-title" style="font-size: 13px;">
                    <i class="fas fa-info-circle me-2"></i>Trạng thái
                </span>
            </div>
            <div class="admin-card-body py-2">
                @* Payment status — compact row *@
                @{
                    var (payIcon, payColor, payLabel) = order?.PaymentStatus switch
                    {
                        PaymentStatus.Paid => ("fas fa-check-circle", "#16a34a", "Đã thanh toán"),
                        PaymentStatus.Pending => ("fas fa-hourglass-half", "#f59e0b", "Chờ thanh toán"),
                        PaymentStatus.Unpaid => ("fas fa-clock", "#6b7280", "Chưa thanh toán (COD)"),
                        PaymentStatus.Failed => ("fas fa-times-circle", "#dc2626", "Thanh toán thất bại"),
                        PaymentStatus.Refunded => ("fas fa-undo-alt", "#3b82f6", "Đã hoàn tiền"),
                        _ => ("fas fa-question-circle", "#6b7280", "Không rõ")
                    };
                }
                <div class="d-flex justify-content-between align-items-center mb-2" style="font-size: 13px;">
                    <span class="text-muted">Thanh toán:</span>
                    <span class="fw-bold" style="color: @payColor;">
                        <i class="@payIcon me-1"></i>@payLabel
                    </span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2" style="font-size: 13px;">
                    <span class="text-muted">Phương thức:</span>
                    <span class="fw-bold">@(string.IsNullOrWhiteSpace(order?.PaymentMethod) ? "COD" : order.PaymentMethod)</span>
                </div>

                @if (order?.PaymentStatus == PaymentStatus.Pending)
                {
                    var expiresAt = order.CreateDate.AddHours(1);
                    var remaining = (int)(expiresAt - DateTime.Now).TotalMinutes;
                    <div class="d-flex justify-content-between align-items-center mb-2" style="font-size: 13px;">
                        <span class="text-muted">Hết hạn TT:</span>
                        <span class="fw-bold @(remaining < 10 ? "text-danger" : "text-warning")">
                            @(remaining > 0 ? $"còn {remaining} phút" : "Đã hết hạn")
                        </span>
                    </div>
                }

                <hr class="my-2" />

                @* Order status update *@
                @if (order?.Status != OrderStatus.Cancelled)
                {
                    <div style="font-size: 13px;">
                        <label for="order-status" class="form-label mb-1 text-muted">Cập nhật trạng thái đơn:</label>
                        <select id="order-status" class="form-select form-select-sm select-update-order">
                            <option value="0" selected="@(order.Status == OrderStatus.New ? "selected" : null)">Đơn hàng mới</option>
                            <option value="1" selected="@(order.Status == OrderStatus.Confirmed ? "selected" : null)">Đã xác nhận</option>
                            <option value="2" selected="@(order.Status == OrderStatus.Processing ? "selected" : null)">Đang đóng gói</option>
                            <option value="3" selected="@(order.Status == OrderStatus.Shipping ? "selected" : null)">Đang giao hàng</option>
                            <option value="4" selected="@(order.Status == OrderStatus.Completed ? "selected" : null)">Hoàn thành</option>
                            <option value="5" selected="@(order.Status == OrderStatus.Cancelled ? "selected" : null)">Hủy đơn</option>
                        </select>
                    </div>
                }
                else
                {
                    <div class="text-center py-1">
                        <span class="status-badge badge-cancelled" style="font-size: 12px;">
                            <i class="fas fa-times-circle"></i> ĐÃ HỦY
                        </span>
                        <p class="text-muted mb-0 mt-1" style="font-size: 11px;">Không thể cập nhật thêm.</p>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        new DataTable('#OrderDetails', {
            layout: {
                topStart: {
                    buttons: ['pdf', 'print']
                }
            }
        });
    </script>

    <script>
        $(document).ready(function () {
            $('.select-update-order').change(function () {
                var status = $(this).val();
                var ordercode = $('.getId').val();

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("UpdateOrder")",
                    data: { status: status, ordercode: ordercode },
                    success: function (result) {
                        if (result.success) {
                            Swal.fire("Cập nhật trạng thái đơn hàng thành công!");
                        } else {
                            Swal.fire("Cập nhật trạng thái đơn hàng thất bại! " + result.message);
                        }
                    },
                    error: function () {
                        Swal.fire("Có lỗi xảy ra khi cập nhật trạng thái đơn hàng.");
                    }
                });
            });
        });
    </script>
}
