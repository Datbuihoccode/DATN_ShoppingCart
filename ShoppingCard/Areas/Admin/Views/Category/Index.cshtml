@using ShoppingCard.Application.DTOs
@model IEnumerable<CategoryDto>
@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Quản lý danh mục</h2>
    <a asp-action="Create" class="btn btn-danger rounded-3 shadow-sm fw-bold">
        <i class="fas fa-plus"></i> Thêm danh mục
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th width="80">ID</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>

                        <th width="120" style="white-space: nowrap;">Trạng thái</th>
                        <th width="180">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><div class="fw-bold">@item.Name</div></td>
                            <td><div class="text-muted small">@Html.Raw(item.Description)</div></td>

                            <td style="white-space: nowrap;">
                                @if(item.Status == 1) {
                                    <span class="status-badge badge-new">Hiển thị</span>
                                } else {
                                    <span class="status-badge badge-cancelled">Ẩn</span>
                                }
                            </td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="Edit" class="btn-admin-edit" asp-route-Id="@item.Id">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" class="btn-admin-delete" asp-route-Id="@item.Id" onclick="return confirm('Xóa danh mục này?');">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>