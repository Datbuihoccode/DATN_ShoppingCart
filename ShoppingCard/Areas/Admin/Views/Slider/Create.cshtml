@model SliderModel
@{
    ViewData["Title"] = "Thêm Slider";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Thêm Slider mới</h2>
    <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="admin-form-card mx-auto">
    <form asp-action="Create" asp-controller="Slider" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="form-group">
            <label class="form-label">Tên Slider *</label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên slider..." />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Trạng thái</label>
                    <select asp-for="Status" class="form-select">
                        <option value="1">Hiển thị</option>
                        <option value="0">Tạm ẩn</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Hình ảnh *</label>
                    <input asp-for="ImageUpload" class="form-control" />
                    <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                    <div id="imgpreview-box" class="img-preview-box mt-3" style="width: 100%; height: 180px; display: none;">
                        <img id="imgpreview" src="#" alt="Preview" />
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn-admin-primary w-100 justify-content-center">
                <i class="fas fa-save"></i> Tạo Slider
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('Description');
        
        $("#ImageUpload").change(function () {
            if (this.files && this.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgpreview').attr('src', e.target.result);
                    $('#imgpreview-box').fadeIn();
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}
