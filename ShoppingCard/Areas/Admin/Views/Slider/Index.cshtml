@model IEnumerable<SliderModel>
@{
    ViewData["Title"] = "Quản lý Slider";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Danh sách Slider</h2>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Thêm Slider
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th style="width: 150px;">Hình ảnh</th>
                        <th>Tên Slider</th>
                        <th>Mô tả</th>
                        <th style="width: 120px;">Trạng thái</th>
                        <th style="width: 160px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <div class="admin-image-box" style="width: 120px; height: 60px;">
                                    <img src="~/media/sliders/@item.Image" alt="@item.Name" />
                                </div>
                            </td>
                            <td><div class="fw-bold">@item.Name</div></td>
                            <td><div class="small text-muted">@Html.Raw(item.Description)</div></td>
                            <td>
                                @if (item.Status == 1)
                                {
                                    <span class="status-badge badge-new"><i class="fas fa-eye me-1"></i> Hiển thị</span>
                                }
                                else
                                {
                                    <span class="status-badge badge-cancelled"><i class="fas fa-eye-slash me-1"></i> Ẩn</span>
                                }
                            </td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="Edit" class="btn-admin-edit" asp-route-Id="@item.Id">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" class="btn-admin-delete confirmDeletion" asp-route-Id="@item.Id" onclick="return confirm('Xác nhận xóa slider này?');">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>