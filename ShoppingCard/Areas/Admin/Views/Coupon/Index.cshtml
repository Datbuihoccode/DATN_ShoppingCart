@model IEnumerable<CouponModel>
@{
    ViewData["title"] = "Danh sách Mã giảm giá";
}

<div class="admin-page-header">
    <div class="d-flex justify-content-between align-items-center w-100">
        <h2 class="admin-page-title">Mã giảm giá (Coupon)</h2>
        <a asp-action="Create" class="btn btn-danger rounded-3 px-4 shadow-sm fw-bold">
            <i class="fas fa-plus-circle me-1"></i> Thêm mã mới
        </a>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <span class="admin-card-title"><i class="fas fa-list me-1"></i> Danh sách mã hiện có</span>
    </div>
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable" data-order='[[ 0, "desc" ]]'>
                <thead>
                    <tr>
                        <th>Mã (Code)</th>
                        <th>Loại giảm giá</th>
                        <th>Đơn tối thiểu</th>
                        <th>Số lượng</th>
                        <th>Thời hạn</th>
                        <th>Trạng thái</th>
                        <th>Quản lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var coupon in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-primary" style="font-size: 15px;">@coupon.Name</div>
                                <div class="small text-muted text-truncate" style="max-width: 180px;" title="@coupon.Description">
                                    @coupon.Description
                                </div>
                            </td>
                            <td>
                                @if (coupon.Type == 1) {
                                    <div class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 fw-bold">
                                        @coupon.DiscountValue.ToString("0")% OFF
                                    </div>
                                    @if(coupon.MaxDiscountAmount > 0) {
                                        <div class="small text-muted mt-1">(Tối đa @coupon.MaxDiscountAmount.ToString("#,##0") đ)</div>
                                    }
                                } else {
                                    <div class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-1 fw-bold">
                                        -@coupon.DiscountValue.ToString("#,##0") đ
                                    </div>
                                }
                            </td>
                            <td class="fw-medium">@coupon.MinAmount.ToString("#,##0") đ</td>
                            <td class="text-center fw-bold">@coupon.Quantity</td>
                            <td>
                                <div class="small text-dark">Bắt đầu: @coupon.DateStart.ToString("dd/MM/yyyy")</div>
                                <div class="small text-danger">Hết hạn: @coupon.DateExpired.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td>
                                <a asp-action="ToggleStatus" asp-route-id="@coupon.Id" class="text-decoration-none">
                                    @if(coupon.Status == 1) {
                                        <span class="badge bg-success rounded-pill px-2">Đang bật</span>
                                    } else {
                                        <span class="badge bg-secondary rounded-pill px-2">Đang tắt</span>
                                    }
                                </a>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@coupon.Id" class="btn btn-sm btn-outline-primary rounded-2" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@coupon.Id" class="btn btn-sm btn-outline-danger rounded-2" 
                                       onclick="return confirm('Xác nhận xóa mã này?');" title="Xóa">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // DataTables is initialized globally in _Layout.cshtml
    </script>
}