@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>
@{
    ViewData["Title"] = "Quản lý quyền hạn";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Danh sách quyền hạn</h2>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Thêm quyền hạn
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th style="width: 300px;">ID</th>
                        <th>Tên quyền hạn</th>
                        <th style="width: 160px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><div class="small text-muted">@item.Id</div></td>
                            <td><div class="fw-bold">@item.Name</div></td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="Edit" class="btn-admin-edit" asp-route-Id="@item.Id">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" class="btn-admin-delete confirmDeletion" asp-route-Id="@item.Id" onclick="return confirm('Xác nhận xóa quyền hạn này?');">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
