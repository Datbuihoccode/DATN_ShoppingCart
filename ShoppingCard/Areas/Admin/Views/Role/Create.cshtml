@using Microsoft.AspNetCore.Identity
@model IdentityRole
@{
    ViewData["Title"] = "Thêm quyền hạn";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Thêm quyền hạn mới</h2>
    <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="admin-form-card mx-auto" style="max-width: 500px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        
        <div class="form-group">
            <label class="form-label">Tên quyền hạn *</label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên quyền (VD: Admin, User)..." />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn-admin-primary w-100 justify-content-center">
                <i class="fas fa-save"></i> Tạo quyền hạn
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
