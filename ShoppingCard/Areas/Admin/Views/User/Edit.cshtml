@model AppUserModel
@{
    ViewData["Title"] = "Gán quyền người dùng";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Gán quyền / Thu hồi quyền người dùng</h2>
    <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="admin-form-card mx-auto">
    <div class="alert alert-info mb-4">
        <i class="fas fa-info-circle me-2"></i> Admin chỉ có quyền thay đổi <strong>Vai trò</strong> của người dùng. Thông tin cá nhân không thể thay đổi tại đây.
    </div>

    <form asp-action="Edit" asp-controller="User" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        
        <div class="form-group">
            <label class="form-label">Họ tên khách hàng</label>
            <input asp-for="FullName" class="form-control bg-light" readonly />
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <input asp-for="UserName" class="form-control bg-light" readonly />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control bg-light" readonly />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control bg-light" readonly />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Vai trò hiện tại / Mới *</label>
                    <select asp-for="RoleId" class="form-select border-primary" style="background-color: #f0f7ff;" asp-items="ViewBag.Roles"></select>
                    <span asp-validation-for="RoleId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Địa chỉ</label>
            <textarea asp-for="Address" class="form-control bg-light" rows="2" readonly></textarea>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn-admin-primary w-100 justify-content-center">
                <i class="fas fa-user-shield"></i> Cập nhật quyền hạn
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
