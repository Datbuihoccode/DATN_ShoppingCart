@model AppUserModel
@{
    ViewData["Title"] = "Cập nhật người dùng";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Cập nhật thông tin người dùng</h2>
    <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="admin-form-card mx-auto">
    <form asp-action="Edit" asp-controller="User" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        
        <div class="form-group">
            <label class="form-label">Họ tên khách hàng</label>
            <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ..." />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập *</label>
                    <input asp-for="UserName" required class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input asp-for="Email" required type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Vai trò *</label>
                    <select asp-for="RoleId" class="form-select" asp-items="ViewBag.Roles"></select>
                    <span asp-validation-for="RoleId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Địa chỉ</label>
            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ đầy đủ"></textarea>
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Hash Mật khẩu (Chỉ đọc)</label>
            <input asp-for="PasswordHash" readonly class="form-control bg-light" style="font-family: monospace; font-size: 12px;" />
            <div class="small text-muted mt-1"><i class="fas fa-info-circle me-1"></i> Mật khẩu đã được mã hóa an toàn.</div>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn-admin-primary w-100 justify-content-center">
                <i class="fas fa-user-check"></i> Cập nhật thông tin
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
