@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Danh sách người dùng</h2>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="fas fa-user-plus"></i> Thêm người dùng
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Vai trò</th>
                        <th width="180">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var userWithRoles in Model)
                    {
                        <tr>
                            <td><div class="fw-bold">@userWithRoles.User.UserName</div></td>
                            <td>@userWithRoles.User.Email</td>
                            <td>@(userWithRoles.User.PhoneNumber ?? "-")</td>
                            <td>
                                @if(userWithRoles.RoleName == "Admin") {
                                    <span class="badge bg-danger">Admin</span>
                                } else {
                                    <span class="badge bg-info text-dark">@userWithRoles.RoleName</span>
                                }
                            </td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="Edit" class="btn-admin-edit" asp-route-Id="@userWithRoles.User.Id">
                                        <i class="fas fa-user-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" class="btn-admin-delete" asp-route-Id="@userWithRoles.User.Id" onclick="return confirm('Xác nhận xóa người dùng này?');">
                                        <i class="fas fa-user-times"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>