@model AppUserModel
@{
    ViewData["Title"] = "Thêm người dùng";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Thêm người dùng mới</h2>
    <a asp-action="Index" class="btn-admin-view" style="background: #f5f6fa; border: 1px solid #ddd; color: #666;">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="admin-form-card mx-auto">
    <form asp-action="Create" asp-controller="User" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        
        <div class="form-group">
            <label class="form-label">Họ tên khách hàng</label>
            <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ..." />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập *</label>
                    <input asp-for="UserName" required class="form-control" placeholder="VD: datbui..." />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input asp-for="Email" type="email" required class="form-control" placeholder="email@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại..." />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label class="form-label">Vai trò *</label>
                    <select asp-for="RoleId" class="form-select" asp-items="ViewBag.Roles">
                        <option value="">-- Chọn vai trò --</option>
                    </select>
                    <span asp-validation-for="RoleId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Địa chỉ</label>
            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ đầy đủ"></textarea>
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Mật khẩu *</label>
            <input asp-for="PasswordHash" type="password" required class="form-control" placeholder="Nhập mật khẩu ít nhất 4 ký tự..." />
            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
        </div>

        <div class="mt-4 pt-3 border-top">
            <button type="submit" class="btn-admin-primary w-100 justify-content-center">
                <i class="fas fa-user-plus"></i> Tạo tài khoản
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
