@using ShoppingCard.Application.DTOs
@using ShoppingCard.Domain.Entities
@model CreateProductDto 
@{
    ViewData["Title"] = "Thêm sản phẩm";
    var allCategories = ViewBag.Categories as IEnumerable<Category> ?? new List<Category>();
}

<nav aria-label="breadcrumb">
    <ol class="admin-breadcrumb">
        <li><a asp-action="Index">Sản phẩm</a></li>
        <li class="sep">/</li>
        <li class="current">Thêm mới</li>
    </ol>
</nav>

<div class="admin-page-header">
    <h2 class="admin-page-title">Thêm sản phẩm mới</h2>
</div>

<div class="admin-form-card mx-auto">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        
        <div class="row">
            <div class="col-md-8">
                <div class="form-group">
                    <label class="form-label">Tên sản phẩm *</label>
                    <input asp-for="Name" class="form-control" id="Name" placeholder="Nhập tên sản phẩm..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Slug</label>
                    <input asp-for="Slug" class="form-control" id="Slug" placeholder="Tự động tạo hoặc nhập slug..." />
                    <span asp-validation-for="Slug" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label class="form-label">Giá bán *</label>
                    <input asp-for="Price" class="form-control typing-price" placeholder="0" />
                    <div id="price-convert" class="price-preview"></div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Khối lượng (gram) *</label>
                    <input asp-for="WeightGram" class="form-control" placeholder="Ví dụ: 2000 (cho 2kg)" />
                    <span asp-validation-for="WeightGram" class="text-danger small"></span>
                    <small class="text-muted">Được sử dụng để tính phí vận chuyển.</small>
                </div>


                <div class="form-group">
                    <label class="form-label">Tình trạng *</label>
                    <select asp-for="Condition" class="form-select" id="Condition">
                        <option value="Mới 100%">Mới 100%</option>
                        <option value="Like New">Like New (Đã qua sử dụng)</option>
                    </select>
                    <small class="text-muted d-block mt-1">Lưu ý: Mới 100% bảo hành 24 tháng, Like New bảo hành 12 tháng.</small>
                    <span asp-validation-for="Condition" class="text-danger small"></span>
                </div>

                @* Danh mục (multi-select dạng checkbox) *@
                <div class="form-group">
                    <label class="form-label">Danh mục * <small class="text-muted">(chọn nhiều)</small></label>
                    <div class="category-checkbox-list border rounded p-2" style="max-height:180px; overflow-y:auto;">
                        @foreach (var cat in allCategories)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="CategoryIds"
                                       value="@cat.Id"
                                       id="cat_@cat.Id" />
                                <label class="form-check-label" for="cat_@cat.Id">
                                    @cat.Name
                                </label>
                            </div>
                        }
                    </div>
                    <span class="text-danger small" id="cat-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Thương hiệu *</label>
                    <select asp-for="BrandId" class="form-select" asp-items="ViewBag.Brands">
                        <option value="">-- Chọn thương hiệu --</option>
                    </select>
                    <span asp-validation-for="BrandId" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Hình ảnh đại diện</label>
                    <input asp-for="ImageUpload" type="file" class="form-control" id="ImageUploadInput" />
                    <span asp-validation-for="ImageUpload" class="text-danger small"></span>
                    <div class="img-preview-box">
                        <img id="imgpreview" src="" />
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top d-flex gap-2">
            <button type="submit" class="btn-admin-primary" id="btnSubmit">
                <i class="fas fa-save"></i> Lưu sản phẩm
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 8px; padding: 9px 20px; font-weight: 600;">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('Description');

        $("#ImageUploadInput").change(function(){
            if (this.files && this.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgpreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(this.files[0]);
            }
        });

        $(".typing-price").on("input", function () {
            var val = $(this).val().replace(/[^\d]/g, "");
            var target = "#price-convert";
            $(target).text(val ? new Intl.NumberFormat("vi-VN").format(val) + " đ" : "");
        });

        $("#Name").on('keyup input', function () {
            var title = $(this).val();
            var slug = title.toLowerCase()
                .normalize('NFD').replace(/[\u0300-\u036f]/g, "")
                .replace(/[đĐ]/g, 'd')
                .replace(/([^0-9a-z-\s])/g, '')
                .replace(/(\s+)/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-+|-+$/g, '');
            $("#Slug").val(slug);
        });

        // Validate: bắt buộc chọn ít nhất 1 danh mục
        $("form").on("submit", function (e) {
            var checked = $("input[name='CategoryIds']:checked").length;
            if (checked === 0) {
                e.preventDefault();
                $("#cat-error").text("Yêu cầu chọn ít nhất 1 danh mục.");
                $(".category-checkbox-list").addClass("border-danger");
            }
        });
        $("input[name='CategoryIds']").on("change", function () {
            if ($("input[name='CategoryIds']:checked").length > 0) {
                $("#cat-error").text("");
                $(".category-checkbox-list").removeClass("border-danger");
            }
        });
    </script>
}
