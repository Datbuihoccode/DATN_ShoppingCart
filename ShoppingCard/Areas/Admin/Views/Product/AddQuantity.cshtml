@model ProductQuantityModel
@{
    ViewData["Title"] = "Add Quantity";
    var totalQuantities = 0;
    var key = 1;
    var productId = ViewBag.ProductId;
    var quantityHistory = ViewBag.ProductByQuantity as List<ProductQuantityModel> ?? new List<ProductQuantityModel>();
}
<div class="container-fluid px-0">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4 class="mb-3">Add Quantity</h4>
            <form asp-action="StoreProductQuantity" asp-controller="Product" enctype="multipart/form-data" class="row g-3 align-items-end">
                <input type="hidden" asp-for="ProductId" value="@productId" />
                <div asp-validation-summary="ModelOnly" class="text-danger col-12"></div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Quantity</label>
                    <input min="1" value="1" max="10000" asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100">Add</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Product By Quantity</h5>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Product ID: @productId</span>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 90px;">Key</th>
                        <th style="width: 180px;">Quantity</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (quantityHistory.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">No quantity history yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var productQuantity in quantityHistory.OrderByDescending(x => x.CreatedDate))
                        {
                            totalQuantities += productQuantity.Quantity;
                            <tr>
                                <td class="fw-semibold text-secondary">#@key</td>
                                <td class="fw-semibold">@productQuantity.Quantity</td>
                                <td>@productQuantity.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            key++;
                        }
                    }
                </tbody>
                <tfoot class="table-group-divider">
                    <tr>
                        <th colspan="2" class="text-end">Total Quantity</th>
                        <th class="text-success fw-bold">@totalQuantities</th>
                    </tr>
                </tfoot>
            </table>
        </div>
        <div class="card-footer bg-white">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List Product</a>
        </div>
    </div>
</div>

<style>
    .table th,
    .table td {
        vertical-align: middle;
    }

    .badge.bg-primary-subtle {
        font-size: 0.85rem;
        font-weight: 600;
    }
</style>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
