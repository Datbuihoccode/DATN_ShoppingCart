@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}



<div class="admin-page-header">
    <h2 class="admin-page-title">Quản lý sản phẩm</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-danger rounded-3 shadow-sm fw-bold">
            <i class="fas fa-plus"></i> Thêm sản phẩm
        </a>
    </div>
</div>

<!-- Filter -->
<div class="row mb-4 align-items-center bg-light p-3 rounded-3 shadow-sm">
    <div class="col-md-3 mb-2 mb-md-0">
        <label class="form-label text-muted small fw-bold mb-1">Hãng sản xuất</label>
        <select id="filterBrand" class="form-select border-0 shadow-sm">
            <option value="">Tất cả Hãng</option>
            @if (ViewBag.Brands != null)
            {
                foreach (var brand in ViewBag.Brands as IEnumerable<BrandModel>)
                {
                    <option value="@brand.Id">@brand.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3 mb-2 mb-md-0">
        <label class="form-label text-muted small fw-bold mb-1">Danh mục</label>
        <select id="filterCategory" class="form-select border-0 shadow-sm">
            <option value="">Tất cả Danh mục</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var category in ViewBag.Categories as IEnumerable<CategoryModel>)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3 mb-2 mb-md-0">
        <label class="form-label text-muted small fw-bold mb-1">Trạng thái</label>
        <select id="filterStatus" class="form-select border-0 shadow-sm">
            <option value="">Tất cả Trạng thái</option>
            <option value="Còn hàng">Còn hàng</option>
            <option value="Sắp hết">Sắp hết</option>
            <option value="Hết hàng">Hết hàng</option>
        </select>
    </div>
    <div class="col-md-3 mb-2 mb-md-0">
        <label class="form-label d-none d-md-block mb-1">&nbsp;</label>
        <button id="resetFilters" class="btn btn-secondary shadow-sm w-100"><i class="fas fa-undo"></i> Đặt lại bộ lọc</button>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th style="width: 100px;">Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Kho</th>
                        <th>Đã bán</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? Enumerable.Empty<ProductModel>())
                    {
                        var statusStr = item.Quantity > 5 ? "Còn hàng" : (item.Quantity > 0 ? "Sắp hết" : "Hết hàng");
                        var categoryIds = string.Join(",", item.ProductCategories.Select(pc => pc.CategoryId));
                        
                        <tr data-brand="@item.BrandId" data-categories="@categoryIds" data-status="@statusStr">
                            <td>
                                <img src="@item.Image" class="rounded product-img" alt="@item.Name" onerror="this.src='https://via.placeholder.com/60'">
                            </td>
                            <td>
                                <div class="product-name truncate" title="@item.Name">@item.Name</div>
                                <div class="small text-muted">ID: #@item.Id</div>
                            </td>
                            <td>
                                <div class="text-success fw-bold">@item.Price.ToString("#,##0")đ</div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Quantity sản phẩm</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary opacity-75">Đã bán @item.Sold</span>
                            </td>
                            <td>
                                @if (item.Quantity > 5)
                                {
                                    <span class="badge bg-success">Còn hàng</span>
                                }
                                else if (item.Quantity > 0)
                                {
                                    <span class="badge bg-warning text-dark">Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="actions-group justify-content-end">
                                    <a asp-action="AddQuantity" asp-route-id="@item.Id" class="btn btn-sm btn-primary" style="padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;">
                                        + Kho
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin-edit">
                                        Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-admin-delete confirmDeletion" onclick="return confirm('Xác nhận xóa sản phẩm này?');">
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#myTable').DataTable();
            
            // Custom filtering function for DataTables
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var filterBrand = $('#filterBrand').val();
                    var filterCategory = $('#filterCategory').val();
                    var filterStatus = $('#filterStatus').val();

                    var tr = $(table.row(dataIndex).node());
                    var brandId = tr.data('brand') ? tr.data('brand').toString() : "";
                    var categoryIds = tr.data('categories') ? tr.data('categories').toString().split(',') : [];
                    var status = tr.data('status') ? tr.data('status').toString() : "";

                    if (filterBrand && filterBrand !== brandId) {
                        return false;
                    }

                    if (filterCategory && !categoryIds.includes(filterCategory)) {
                        return false;
                    }

                    if (filterStatus && filterStatus !== status) {
                        return false;
                    }

                    return true;
                }
            );

            // Trigger filtering when selects change
            $('#filterBrand, #filterCategory, #filterStatus').on('change', function() {
                table.draw();
            });

            // Reset filters
            $('#resetFilters').on('click', function() {
                $('#filterBrand').val('');
                $('#filterCategory').val('');
                $('#filterStatus').val('');
                table.draw();
            });
        });
    </script>
}
