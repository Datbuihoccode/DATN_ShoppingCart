@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

@section Styles {
    <style>
        .product-name {
            font-weight: 600;
            max-width: 450px;
            font-size: 16px;
        }

        .truncate {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .product-img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 10px;
        }
        
        .filter-buttons .btn {
            border-radius: 20px;
            padding: 6px 20px;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .filter-buttons .btn.active {
            box-shadow: 0 3px 8px rgba(0,0,0,0.15);
        }

        /* Đồng nhất với theme nhưng giữ kích thước 'to' như yêu cầu */
        .admin-table thead th {
            color: #4e73df; /* Màu xanh theme hệ thống */
        }

        .badge {
            font-weight: 600;
            padding: 6px 12px;
            font-size: 12px;
        }
    </style>
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Quản lý sản phẩm</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn-admin-primary">
            <i class="fas fa-plus"></i> Thêm sản phẩm
        </a>
    </div>
</div>

<!-- Filter -->
<div class="mb-4 filter-buttons d-flex gap-2 flex-wrap">
    <button class="btn btn-sm btn-outline-dark active" data-filter="all">Tất cả</button>
    <button class="btn btn-sm btn-outline-success" data-filter="conhang">Còn hàng</button>
    <button class="btn btn-sm btn-outline-warning" data-filter="saphet">Sắp hết</button>
    <button class="btn btn-sm btn-outline-danger" data-filter="hethang">Hết hàng</button>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th style="width: 100px;">Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Kho</th>
                        <th>Đã bán</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? Enumerable.Empty<ProductModel>())
                    {
                        <tr>
                            <td>
                                <img src="@item.Image" class="rounded product-img" alt="@item.Name" onerror="this.src='https://via.placeholder.com/60'">
                            </td>
                            <td>
                                <div class="product-name truncate" title="@item.Name">@item.Name</div>
                                <div class="small text-muted">ID: #@item.Id</div>
                            </td>
                            <td>
                                <div class="text-success fw-bold">@item.Price.ToString("#,##0")đ</div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Quantity sản phẩm</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary opacity-75">Đã bán @item.Sold</span>
                            </td>
                            <td>
                                @if (item.Quantity > 5)
                                {
                                    <span class="badge bg-success">Còn hàng</span>
                                }
                                else if (item.Quantity > 0)
                                {
                                    <span class="badge bg-warning text-dark">Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="actions-group justify-content-end">
                                    <a asp-action="AddQuantity" asp-route-id="@item.Id" class="btn btn-sm btn-primary" style="padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;">
                                        + Kho
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-admin-edit">
                                        Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-admin-delete confirmDeletion" onclick="return confirm('Xác nhận xóa sản phẩm này?');">
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#myTable').DataTable();
            
            $('.filter-buttons button').on('click', function() {
                var filter = $(this).data('filter');
                $('.filter-buttons button').removeClass('active');
                $(this).addClass('active');
                
                if (filter === 'all') {
                    table.column(5).search('').draw();
                } else if (filter === 'conhang') {
                    table.column(5).search('Còn hàng').draw();
                } else if (filter === 'saphet') {
                    table.column(5).search('Sắp hết').draw();
                } else if (filter === 'hethang') {
                    table.column(5).search('Hết hàng').draw();
                }
            });
        });
    </script>
}
