@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Danh sách sản phẩm</h2>
    <a asp-action="Create" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Thêm sản phẩm
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="admin-table" id="myTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá bán</th>
                        <th>Số lượng</th>
                        <th>Danh mục</th>
                        <th>Thương hiệu</th>
                        <th>Quản lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: #f0f2f5; display: flex; align-items: center; justify-content: center;">
                                    <img src="@item.Image" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <div class="small text-muted">@item.Slug</div>
                            </td>
                            <td>
                                <div class="fw-bold text-danger">@item.Price.ToString("#,##0 VND")</div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Quantity</div>
                                <div class="small text-muted">Đã bán: @item.Sold</div>
                                <a asp-action="AddQuantity" asp-route-Id="@item.Id" class="text-primary small" style="text-decoration: underline;">Nhập thêm</a>
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.Category.Name</span></td>
                            <td><span class="badge bg-light text-dark border">@item.Brand.Name</span></td>
                            <td>
                                <div class="actions-group">
                                    <a asp-action="Edit" class="btn-admin-edit" asp-route-Id="@item.Id">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" class="btn-admin-delete confirmDeletion" asp-route-Id="@item.Id" onclick="return confirm('Xác nhận xóa sản phẩm này?');">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
