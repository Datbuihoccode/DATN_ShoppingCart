<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - LaptopCenter Admin</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- DataTables -->
    <link href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/buttons/3.2.6/css/buttons.dataTables.css" rel="stylesheet">
    <!-- Morris Charts -->
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/morris.js/0.5.1/morris.css">
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.min.css" rel="stylesheet">
    <!-- Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet">
</head>
<body>
<div class="admin-wrapper">

    <!-- ===== SIDEBAR ===== -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-text"><span>LAPTOP</span>CENTER</div>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-title">Tổng quan</div>
            <a asp-action="Index" asp-controller="Dashboard" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fas fa-chart-line"></i><span>Dashboard</span>
            </a>

            <div class="sidebar-section-title">Danh mục</div>
            <a asp-action="Index" asp-controller="Product" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                <i class="fas fa-box-open"></i><span>Sản phẩm</span>
            </a>
            <a asp-action="Index" asp-controller="Category" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                <i class="fas fa-tags"></i><span>Danh mục</span>
            </a>
            <a asp-action="Index" asp-controller="Brand" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Brand" ? "active" : "")">
                <i class="fas fa-trademark"></i><span>Thương hiệu</span>
            </a>
            <a asp-action="Index" asp-controller="Slider" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Slider" ? "active" : "")">
                <i class="fas fa-images"></i><span>Slider</span>
            </a>

            <div class="sidebar-section-title">Kinh doanh</div>
            <a asp-action="Index" asp-controller="Order" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                <i class="fas fa-shopping-bag"></i><span>Đơn hàng</span>
            </a>
            <a asp-action="Index" asp-controller="Coupon" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")">
                <i class="fas fa-ticket-alt"></i><span>Mã giảm giá</span>
            </a>

            <div class="sidebar-section-title">Hệ thống</div>
            <a asp-action="Index" asp-controller="User" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                <i class="fas fa-users"></i><span>Người dùng</span>
            </a>
            <a asp-action="Index" asp-controller="Role" asp-area="Admin"
               class="sidebar-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Role" ? "active" : "")">
                <i class="fas fa-user-shield"></i><span>Quyền hạn</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a asp-action="Index" asp-controller="Home" asp-area="">
                <i class="fas fa-store"></i><span>Về trang chủ</span>
            </a>
        </div>
    </aside>

    <!-- ===== MAIN ===== -->
    <div class="admin-main">

        <!-- TOPBAR -->
        <header class="admin-topbar">
            <div class="d-flex align-items-center gap-3">
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>
            <div class="topbar-right">
                <a href="/" class="topbar-icon-btn" title="Xem trang web">
                    <i class="fas fa-external-link-alt"></i>
                </a>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="topbar-user dropdown">
                        <div class="topbar-user-avatar dropdown-toggle" data-bs-toggle="dropdown">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                        </div>
                        <span class="topbar-user-name d-none d-md-block">@User.Identity.Name</span>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 10px; min-width: 180px; padding: 8px;">
                            <li><a class="dropdown-item" asp-action="Logout" asp-controller="Account" asp-area="">
                                <i class="fas fa-sign-out-alt me-2 text-danger"></i>Đăng xuất
                            </a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-action="Login" asp-controller="Account" asp-area="" class="btn-admin-primary" style="padding: 7px 16px; font-size: 13px;">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập
                    </a>
                }
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="admin-content">
            @RenderBody()
        </main>

    </div><!-- /admin-main -->
</div><!-- /admin-wrapper -->

<!-- Scripts -->
<script src="~/js/jquery.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- DataTables -->
<script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/3.2.6/js/dataTables.buttons.js"></script>
<script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.dataTables.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.print.min.js"></script>

<!-- Morris Charts -->
<script src="//cdnjs.cloudflare.com/ajax/libs/raphael/2.1.0/raphael-min.js"></script>
<script src="//cdnjs.cloudflare.com/ajax/libs/morris.js/0.5.1/morris.min.js"></script>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.all.min.js"></script>

<script>
    // Auto-init DataTable for #myTable
    $(function () {
        if ($('#myTable').length && !$.fn.DataTable.isDataTable('#myTable')) {
            new DataTable('#myTable', {
                layout: {
                    topStart: {
                        buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
                    }
                },
                language: {
                    search: "Tìm kiếm:",
                    lengthMenu: "Hiển thị _MENU_ dòng",
                    info: "Đang hiện _START_ - _END_ trong _TOTAL_ bản ghi",
                    paginate: { first: "«", last: "»", next: "›", previous: "‹" },
                    zeroRecords: "Không có dữ liệu",
                    infoEmpty: "Không có bản ghi nào"
                }
            });
        }

        // SweetAlert success notification
        var msg = '@Html.Raw(TempData["success"])';
        if (msg && msg.trim() !== '') {
            Swal.fire({ icon: 'success', title: 'Thành công!', text: msg, timer: 3000, showConfirmButton: false });
        }
        var err = '@Html.Raw(TempData["error"])';
        if (err && err.trim() !== '') {
            Swal.fire({ icon: 'error', title: 'Lỗi!', text: err });
        }
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
