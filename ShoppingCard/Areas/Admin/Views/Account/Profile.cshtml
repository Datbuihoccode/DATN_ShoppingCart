@model AdminProfileViewModel

@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<div class="admin-page-header">
    <h2 class="admin-page-title">Tài khoản của tôi</h2>
</div>

<div class="row g-4">

    @* ===== TRÁI: Thông tin hiện tại ===== *@
    <div class="col-lg-4">
        <div class="admin-card p-4 h-100 text-center" style="border-radius: 20px;">

            @* Avatar *@
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="/media/avatars/@Model.AvatarUrl" alt="Avatar"
                     class="mx-auto mb-3 d-block rounded-circle object-fit-cover border"
                     style="width: 100px; height: 100px; border-width: 3px !important; border-color: #e2e8f0 !important;">
            }
            else
            {
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center fw-bold text-white"
                     style="width: 100px; height: 100px; border-radius: 50%;
                            background: linear-gradient(135deg, #4f46e5, #7c3aed); font-size: 40px;">
                    @(Model.UserName?.Substring(0, 1).ToUpper())
                </div>
            }

            <h4 class="fw-bold mb-1">@Model.UserName</h4>
            <span class="badge rounded-pill px-3 py-1 small fw-semibold mb-3"
                  style="background: rgba(79,70,229,0.1); color: #4f46e5;">
                <i class="fas fa-shield-alt me-1"></i> Quản trị viên
            </span>

            <hr class="my-3">

            <div class="text-start">
                <div class="mb-3">
                    <p class="text-muted mb-1 fw-semibold text-uppercase" style="font-size: 12px;">
                        <i class="fas fa-user me-1"></i> Tên đăng nhập
                    </p>
                    <p class="fw-semibold mb-0" style="font-size: 16px;">@Model.UserName</p>
                </div>
                <div class="mb-3">
                    <p class="text-muted mb-1 fw-semibold text-uppercase" style="font-size: 12px;">
                        <i class="fas fa-shield-alt me-1"></i> Quyền hạn
                    </p>
                    <div class="d-flex flex-wrap gap-1 mt-1">
                        @if (Model.Roles != null && Model.Roles.Any())
                        {
                            foreach (var role in Model.Roles)
                            {
                                <span class="badge rounded-pill px-3 py-1 fw-semibold"
                                      style="background: rgba(79,70,229,0.12); color: #4f46e5; font-size: 13px;">
                                    @role
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted" style="font-size: 15px;">Chưa phân quyền</span>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <p class="text-muted mb-1 fw-semibold text-uppercase" style="font-size: 12px;">
                        <i class="fas fa-envelope me-1"></i> Email
                    </p>
                    <p class="fw-semibold mb-0 text-truncate" style="font-size: 16px;">
                        @(string.IsNullOrEmpty(Model.Email) ? "Chưa cập nhật" : Model.Email)
                    </p>
                </div>
                <div class="mb-0">
                    <p class="text-muted mb-1 fw-semibold text-uppercase" style="font-size: 12px;">
                        <i class="fas fa-phone me-1"></i> Số điện thoại
                    </p>
                    <p class="fw-semibold mb-0" style="font-size: 16px;">
                        @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)
                    </p>
                </div>
            </div>
        </div>
    </div>

    @* ===== PHẢI: Form chỉnh sửa ===== *@
    <div class="col-lg-8">
        <div class="admin-card p-4" style="border-radius: 20px;">
            <h6 class="fw-bold mb-4 pb-2 border-bottom">
                <i class="fas fa-edit me-2 text-primary"></i>Chỉnh sửa thông tin
            </h6>

            <form asp-action="Profile" method="post" enctype="multipart/form-data" autocomplete="off">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                @* Upload Avatar *@
                <div class="mb-4">
                    <label asp-for="AvatarUpload" class="form-label small fw-medium text-muted"></label>
                    <div class="d-flex align-items-center gap-3">
                        <div id="avatarPreviewWrap">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img id="avatarPreview" src="/media/avatars/@Model.AvatarUrl"
                                     class="rounded-circle object-fit-cover border"
                                     style="width:52px; height:52px; border-color:#e2e8f0 !important;">
                            }
                            else
                            {
                                <div id="avatarPreview" class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                     style="width:52px; height:52px; background: linear-gradient(135deg,#4f46e5,#7c3aed); font-size:20px; flex-shrink:0;">
                                    @(Model.UserName?.Substring(0, 1).ToUpper())
                                </div>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <input asp-for="AvatarUpload" type="file" class="form-control" id="avatarInput"
                                   accept="image/*" onchange="previewAvatar(this)" />
                            <div class="form-text">Hỗ trợ JPG, PNG, GIF. Tối đa 2MB.</div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-medium text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fas fa-envelope text-muted" style="font-size:13px;"></i>
                        </span>
                        <input asp-for="Email" class="form-control border-start-0 ps-1" placeholder="admin@@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label small fw-medium text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fas fa-phone text-muted" style="font-size:13px;"></i>
                        </span>
                        <input asp-for="PhoneNumber" class="form-control border-start-0 ps-1" placeholder="0901 234 567" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <hr class="my-3">
                <p class="small text-muted mb-3">
                    <i class="fas fa-lock me-1"></i>Đổi mật khẩu — để trống nếu không muốn đổi
                </p>

                <div class="mb-4">
                    <label asp-for="NewPassword" class="form-label small fw-medium text-muted"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fas fa-key text-muted" style="font-size:13px;"></i>
                        </span>
                        <input asp-for="NewPassword" type="password" id="NewPassword"
                               class="form-control border-start-0 ps-1" placeholder="••••••••" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePw()">
                            <i class="fas fa-eye" id="pwIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" asp-controller="Dashboard" asp-area="Admin"
                       class="btn btn-light px-4 rounded-3">Hủy</a>
                    <button type="submit" class="btn btn-primary px-4 rounded-3 fw-semibold">
                        <i class="fas fa-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePw() {
            const input = document.getElementById('NewPassword');
            const icon  = document.getElementById('pwIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        function previewAvatar(input) {
            if (!input.files || !input.files[0]) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                const wrap = document.getElementById('avatarPreviewWrap');
                wrap.innerHTML = `<img id="avatarPreview" src="${e.target.result}"
                    class="rounded-circle object-fit-cover border"
                    style="width:52px; height:52px; border-color:#e2e8f0 !important;">`;
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}
