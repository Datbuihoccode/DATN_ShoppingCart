{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GoogleKeys": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "MomoApi": {
    "MomoApiUrl": "https://test-payment.momo.vn/v2/gateway/api/create",
    "SecretKey": "YOUR_MOMO_SECRET_KEY",
    "AccessKey": "YOUR_MOMO_ACCESS_KEY",
    "ReturnUrl": "https://localhost:7210/Checkout/PaymentCallBack",
    "NotifyUrl": "https://localhost:7210/Payment/MomoNotify",
    "PartnerCode": "MOMO",
    "RequestType": "captureWallet"
  },
  "Vnpay": {
    "TmnCode": "YOUR_VNPAY_TMN_CODE",
    "HashSecret": "YOUR_VNPAY_HASH_SECRET",
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "Command": "pay",
    "CurrCode": "VND",
    "Version": "2.1.0",
    "Locale": "vn",
    "PaymentBackReturnUrl": "/Checkout/PaymentCallBackVnPay",
    "TimeZoneId": "SE Asia Standard Time"
  },
  "ShippingApi": {
    "Enabled": true,
    "Provider": "GHN",
    "BaseUrl": "https://dev-online-gateway.ghn.vn",
    "Token": "YOUR_GHN_TOKEN",
    "ShopId": 0,
    "FromDistrictId": 0,
    "FromWardCode": "YOUR_WARD_CODE",
    "FromName": "Laptop Center",
    "FromPhone": "YOUR_PHONE",
    "FromAddress": "YOUR_ADDRESS",
    "FromWardName": "YOUR_WARD_NAME",
    "FromDistrictName": "YOUR_DISTRICT_NAME",
    "FromProvinceName": "YOUR_PROVINCE_NAME",
    "FromProvinceId": 0,
    "IsNewFromAddress": true,
    "ServiceTypeId": 2,
    "DefaultItemWeightGram": 2200
  },
  "ConnectionStrings": {
    "ConnectedDb": "Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;TrustServerCertificate=True"
  }
}
