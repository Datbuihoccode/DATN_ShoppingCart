@model ShoppingCard.Models.ViewsModels.HomeIndexViewModel
@{
	ViewData["Title"] = "Trang chủ";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
	<!-- Slider full width -->
	<div class="row mb-4">
		<div class="col-12">
			<partial name="_SliderPartial" />
		</div>
	</div>

	@foreach (var categorySection in Model.Sections)
	{
		var categoryProducts = categorySection.Products;

		<div class="category-block">
			<div class="category-header">
				<h2 class="section-title">
					@categorySection.CategoryName.ToUpper()
				</h2>
				
				<div class="category-filters">
					<span class="text-muted fw-bold me-2">Mức giá:</span>
					<a href="/Category/@categorySection.CategorySlug?startprice=0&endprice=10000000" class="filter-pill">Dưới 10 triệu</a>
					<a href="/Category/@categorySection.CategorySlug?startprice=10000000&endprice=20000000" class="filter-pill">10 - 20 triệu</a>
					<a href="/Category/@categorySection.CategorySlug?startprice=20000000&endprice=30000000" class="filter-pill">20 - 30 triệu</a>
					<a href="/Category/@categorySection.CategorySlug?startprice=30000000&endprice=40000000" class="filter-pill">30 - 40 triệu</a>
					<a href="/Category/@categorySection.CategorySlug?startprice=40000000&endprice=999000000" class="filter-pill">Trên 40 triệu</a>
				</div>
			</div>

			<!-- Carousel Slider -->
			<div class="position-relative">
				<div id="slider-@categorySection.CategoryId" class="product-slider-container pb-3 px-2">
					@foreach (var item in categoryProducts)
					{
						<div class="product-slider-item">
							<div class="laptopcenter-card h-100">
								<a href="javascript:void(0)" class="laptopcenter-card-wishlist add-to-wishlist" data-product_id="@item.Id" title="Thêm vào yêu thích">
									<i class="fa fa-heart"></i>
								</a>

								<a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug">
									<div class="laptopcenter-card-img">
										<img src="@item.ImagePath" alt="@item.Name" />
									</div>
								</a>

								<div class="laptopcenter-card-body">
									<a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug" class="laptopcenter-card-title">
										@item.Name
									</a>

									<div class="laptopcenter-card-price">
										@item.Price.ToString("#,##0 đ")
									</div>

									<div class="laptopcenter-card-specs">
										<span class="laptopcenter-spec-item"><i class="fa fa-building"></i> @item.Brand?.Name</span>
										<span class="laptopcenter-spec-item text-success"><i class="fa fa-check-circle"></i> @(string.IsNullOrEmpty(item.Condition) ? "Mới 100%" : item.Condition)</span>
									</div>

									<div class="laptopcenter-card-actions mt-auto">
										@if(item.Quantity > 0)
										{
											<button class="btn-brand w-100 add-to-cart" data-product_id="@item.Id">
												<i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
											</button>
										}
										else
										{
											<button class="btn-brand btn-disabled w-100" disabled>
												<i class="fa fa-ban me-1"></i> Hết hàng
											</button>
										}
									</div>
								</div>
							</div>
						</div>
					}
				</div>

				@if(categoryProducts.Count > 5) {
					<button class="slider-nav-btn slider-prev" type="button" onclick="document.getElementById('slider-@categorySection.CategoryId').scrollBy({left: -250, behavior: 'smooth'})">
						<i class="fa fa-chevron-left"></i>
					</button>
					<button class="slider-nav-btn slider-next" type="button" onclick="document.getElementById('slider-@categorySection.CategoryId').scrollBy({left: 250, behavior: 'smooth'})">
						<i class="fa fa-chevron-right"></i>
					</button>
				}
			</div>
			<div class="mt-4 text-center">
				<a asp-controller="Category" asp-action="Index" asp-route-slug="@categorySection.CategorySlug" class="btn-view-all">
					Xem thêm @categorySection.CategoryName.ToUpper() <i class="fa fa-arrow-right ms-2"></i>
				</a>
			</div>
		</div>
	}
</div>
