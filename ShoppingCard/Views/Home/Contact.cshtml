@model ContactModel

    <div>
        <p>@Html.Raw(Model.Description)</p>
    </div>
    <div>
        @Html.Raw(Model.Map)
    </div>
    <div>
        <div class="contact-info" style="margin-top: 20px;">
            <p><strong>Name :</strong> @Model.Name</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
        </div>
    </div>

