@model IEnumerable<WishlistModel>
@{
    ViewData["Title"] = "Yêu thích";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb" style="background: transparent; padding: 0;">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active text-muted">Danh sách yêu thích</li>
        </ol>
    </nav>

    <h2 class="section-title mb-4">Danh Sách Yêu Thích</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa fa-heart" style="font-size: 70px; color: #e8ecf0;"></i>
            <h4 class="mt-3 fw-bold" style="color: #555;">Danh sách yêu thích đang trống</h4>
            <p class="text-muted mb-4">Hãy khám phá sản phẩm và nhấn ❤️ để lưu lại nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn-brand" style="width: auto; display: inline-block; padding: 12px 35px;">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                if (item.Product == null) { continue; }

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card">
                        <!-- Nút xóa -->
                        <button class="remove-wishlist-btn btn-remove-wishlist" data-product_id="@item.ProductId" title="Xóa khỏi Wishlist">
                            <i class="fa fa-times"></i>
                        </button>

                        <!-- Ảnh sản phẩm -->
                        <a asp-controller="Product" asp-action="Details" asp-route-Id="@item.ProductId" class="product-img-box">
                            <img src="@item.Product.Image" alt="@item.Product.Name" />
                        </a>

                        <div class="product-info">
                            <a asp-controller="Product" asp-action="Details" asp-route-Id="@item.ProductId" class="product-name">
                                @item.Product.Name
                            </a>

                            <div class="product-price">
                                @item.Product.Price.ToString("#,##0 VNĐ")
                            </div>

                            <div class="product-specs mb-2">
                                @if (item.Product.Category != null)
                                {
                                    <span class="spec-item">@item.Product.Category.Name</span>
                                }
                                @if (item.Product.Brand != null)
                                {
                                    <span class="spec-item">@item.Product.Brand.Name</span>
                                }
                            </div>

                            <!-- Action Button -->
                            <a class="btn-action-primary add-to-cart" href="javascript:void(0)" data-product_id="@item.ProductId" style="text-align: center; display: block;">
                                <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
