@model IEnumerable<WishlistModel>
@{
    ViewData["Title"] = "Wishlist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section id="wishlist-page" class="wishlist-wrap">
    <div class="container">
        <div class="breadcrumbs mb-4">
            <ol class="breadcrumb">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="active">Wishlist</li>
            </ol>
        </div>

        <h2 class="title text-center" style="margin-bottom: 30px;">Danh Sách Yêu Thích</h2>

        @if (Model == null || !Model.Any())
        {
            <div class="wishlist-empty">
                <i class="fa fa-heart-o" style="font-size: 60px; color: #ddd; margin-bottom: 20px;"></i>
                <h4 style="color: #666;">Wishlist của bạn đang trống.</h4>
                <a asp-controller="Home" asp-action="Index" class="btn btn-warning" style="margin-top: 15px; padding: 10px 25px; font-weight: 600;">
                    Tiếp tục mua sắm
                </a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var item in Model)
                {
                    if (item.Product == null)
                    {
                        continue;
                    }

                    <div class="col-sm-6 col-md-4 col-lg-3 product-wrapper" style="margin-bottom: 30px;">
                        <div class="product-card">
                            <!-- Nút xóa -->
                            <button class="remove-wishlist-btn btn-remove-wishlist" data-product_id="@item.ProductId" title="Xóa khỏi Wishlist">
                                <i class="fa fa-times"></i>
                            </button>

                            <!-- Ảnh sản phẩm -->
                            <a asp-controller="Product" asp-action="Details" asp-route-Id="@item.ProductId" class="product-img-box">
                                <img src="~/media/products/@item.Product.Image" alt="@item.Product.Name" />
                            </a>

                            <div class="product-info">
                                <!-- Tên sản phẩm -->
                                <a asp-controller="Product" asp-action="Details" asp-route-Id="@item.ProductId" class="product-name">
                                    @item.Product.Name
                                </a>
                                
                                <!-- Giá -->
                                <div class="product-price">
                                    @item.Product.Price.ToString("#,##0 VND")
                                </div>
                                
                                <!-- Thông số cơ bản (Mockup for Laptop) -->
                                <div class="product-specs">
                                    <span class="spec-item"><i class="fa fa-microchip"></i> Core i5/i7</span>
                                    <span class="spec-item"><i class="fa fa-memory"></i> 8GB/16GB</span>
                                    <span class="spec-item"><i class="fa fa-hdd-o"></i> 512GB SSD</span>
                                </div>

                                <!-- Action Buttons -->
                                <div class="product-actions">
                                    <a class="btn btn-action-primary" asp-controller="Cart" asp-action="Add" asp-route-Id="@item.ProductId">
                                        <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> Thêm vào giỏ hàng
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>


