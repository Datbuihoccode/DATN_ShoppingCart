@model IEnumerable<ProductModel>
@{
	ViewData["Title"] = ViewBag.Keyword;
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h2 class="section-title">Kết quả: "@ViewBag.Keyword"</h2>

            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa fa-search text-muted" style="font-size: 60px;"></i>
                    <h4 class="mt-3 text-muted">Không tìm thấy sản phẩm phù hợp.</h4>
                    <a href="/" class="btn-brand d-inline-block mt-3" style="width: auto; padding: 10px 30px;">Quay về trang chủ</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-6 col-md-3">
                            <div class="laptopcenter-card h-100">
                                <a href="javascript:void(0)" class="laptopcenter-card-wishlist add-to-wishlist" data-product_id="@item.Id">
                                    <i class="fa fa-heart"></i>
                                </a>
                                <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug">
                                    <div class="laptopcenter-card-img">
                                        <img src="@item.Image" alt="@item.Name" />
                                    </div>
                                </a>
                                <div class="laptopcenter-card-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug" class="laptopcenter-card-title">
                                        @item.Name
                                    </a>
                                    <div class="laptopcenter-card-price">@item.Price.ToString("#,##0 đ")</div>
                                    <div class="laptopcenter-card-specs">
                                        <span class="laptopcenter-spec-item">@(item.ProductCategories?.FirstOrDefault()?.Category?.Name ?? "Laptop")</span>
                                        <span class="laptopcenter-spec-item">@item.Brand?.Name</span>
                                    </div>
                                    <div class="laptopcenter-card-actions mt-auto">
                                        @if(item.Quantity > 0)
                                        {
                                            <a class="btn-brand add-to-cart" href="javascript:void(0)" data-product_id="@item.Id">
                                                <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn-brand btn-disabled" disabled>Hết hàng</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
