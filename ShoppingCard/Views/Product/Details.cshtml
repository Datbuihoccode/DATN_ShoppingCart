@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductDetails.Name;
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}



<div class="container py-4">
<div class="row">
	<div class="col-12">
        
        <!-- Khung hiển thị Chi tiết -->
        <div class="laptopcenter-detail-wrap row g-0">
            <div class="col-md-6">
                <div class="laptopcenter-detail-img p-4">
                    <img src="@Model.ProductDetails.Image" alt="@Model.ProductDetails.Name" class="img-fluid" />
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="laptopcenter-detail-info p-4">
                    <h1>@Model.ProductDetails.Name</h1>
                    
                    @{
                        decimal averageRating = 0;
                        int totalRatings = 0;
                        if (Model.ProductDetails.Ratings != null && Model.ProductDetails.Ratings.Any())
                        {
                            averageRating = (decimal)Model.ProductDetails.Ratings.Average(r => int.TryParse(r.Star, out int s) ? s : 5);
                            totalRatings = Model.ProductDetails.Ratings.Count();
                        }
                    }

                    <div class="product-rating-summary mb-3 d-flex align-items-center">
                        <div class="stars me-2" style="color: #ffc107;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Round(averageRating))
                                {
                                    <i class="fa fa-star"></i>
                                }
                                else
                                {
                                    <i class="far fa-star"></i>
                                }
                            }
                        </div>
                        <span class="text-muted small">
                            <strong>@averageRating.ToString("0.0")</strong> (@totalRatings đánh giá)
                        </span>
                    </div>

                    <div class="laptopcenter-detail-price">
                        @Model.ProductDetails.Price.ToString("#,##0 VNĐ")
                    </div>
                    
                    <div class="laptopcenter-detail-specs">
                        <p><strong><i class="fa fa-building"></i> Thương hiệu:</strong> @Model.ProductDetails.Brand?.Name</p>
                        <p><strong><i class="fa fa-check-circle"></i> Tình trạng:</strong> @(string.IsNullOrEmpty(Model.ProductDetails.Condition) ? "Mới 100%" : Model.ProductDetails.Condition)</p>
                        <p><strong><i class="fa fa-shield-alt"></i> Bảo hành:</strong> 12 Tháng chính hãng</p>
                    </div>

                    <div class="laptopcenter-detail-action">
                        @if(Model.ProductDetails.Quantity > 0){
                            <input type="number" class="quantity-input" value="1" min="1" max="@Model.ProductDetails.Quantity" title="Số lượng" />
                            <a class="btn-buy-now add-to-cart" href="javascript:void(0)" data-product_id="@Model.ProductDetails.Id">
                                <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> THÊM VÀO GIỎ
                            </a>
                        }
                        else{
                            <button class="btn-disabled-large" disabled>
                                <i class="fa fa-ban" style="margin-right: 5px;"></i> HẾT HÀNG
                            </button>
                        }
                        <!-- Wishlist button (tận dụng từ techstore.css) -->
                         <a href="javascript:void(0)" class="btn-wishlist-large add-to-wishlist" data-product_id="@Model.ProductDetails.Id" title="Lưu yêu thích">
                            <i class="fa fa-heart"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khối Thông tin Tabs -->
        <div class="laptopcenter-tabs">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab">Thông số kỹ thuật</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">Đánh giá & Bình luận</button>
                </li>
            </ul>
            
            <div class="tab-content">
                <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
                    <div style="line-height: 1.8; color: #555;">
                        @{
                            var rawDesc = Model.ProductDetails.Description ?? "";
                            if (rawDesc.Contains("|"))
                            {
                                var parts = rawDesc.Split('|', StringSplitOptions.RemoveEmptyEntries);
                                <table class="table table-bordered table-striped mt-3" style="width: 100%;">
                                    <tbody>
                                        @foreach (var p in parts)
                                        {
                                            var pTrim = p.Trim();
                                            var colonIndex = pTrim.IndexOf(':');
                                            // Handle special cases where colon might be part of an inner string
                                            if (colonIndex > 0 && colonIndex < 30) // Assuming property names are short
                                            {
                                                <tr>
                                                    <td style="width: 30%; font-weight: bold; background-color: #f8f9fa;">@pTrim.Substring(0, colonIndex).Trim()</td>
                                                    <td>@pTrim.Substring(colonIndex + 1).Trim()</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="2">@pTrim</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                @Html.Raw(rawDesc)
                            }
                        }
                    </div>
                </div>

                <div class="tab-pane fade" id="reviews" role="tabpanel" aria-labelledby="reviews-tab">
                    <div class="row">
                        <div class="col-md-6 border-end">
                            <h5 class="fw-bold mb-4" style="color: var(--text-main);">Đánh giá từ khách hàng</h5>
                            
                            @if (Model.ProductDetails.Ratings != null && Model.ProductDetails.Ratings.Any())
                            {
                                <div class="review-list">
                                    @foreach (var r in Model.ProductDetails.Ratings.OrderByDescending(x => x.Id))
                                    {
                                        <div class="review-item mb-4 pb-3 border-bottom">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <strong class="text-dark">@r.Name</strong>
                                                    <span class="badge bg-success ms-2" style="font-size: 10px;"><i class="fa fa-check-circle"></i> Đã mua hàng</span>
                                                </div>
                                            </div>
                                            <div class="review-stars mb-2" style="color: #ffc107;">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= (int.TryParse(r.Star, out int s) ? s : 5))
                                                    {
                                                        <i class="fa fa-star"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="far fa-star"></i>
                                                    }
                                                }
                                            </div>
                                            <p class="mb-0 text-secondary" style="font-style: italic;">"@r.Comment"</p>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5 text-muted">
                                    <i class="fa fa-comment-slash fa-3x mb-3" style="opacity: 0.2;"></i>
                                    <p>Chưa có đánh giá nào cho sản phẩm này.</p>
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-4" style="color: var(--text-main);">Viết đánh giá của bạn</h5>
                            <div class="review-form">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    @if (ViewBag.HasPurchased)
                                    {
                                        <form autocomplete="off" action="/comment-product" method="POST">
                                            @Html.AntiForgeryToken()
                                            <input asp-for="@Model.ProductDetails.Id" name="ProductId" type="hidden" />
                                            
                                            <div class="lc-rating-picker mb-3">
                                                <label class="form-label d-block mb-1">Mức độ hài lòng của bạn:</label>
                                                <div class="stars-select fs-4" style="color: #ffc107; cursor: pointer;">
                                                    <i class="fa fa-star star-select" data-value="1"></i>
                                                    <i class="fa fa-star star-select" data-value="2"></i>
                                                    <i class="fa fa-star star-select" data-value="3"></i>
                                                    <i class="fa fa-star star-select" data-value="4"></i>
                                                    <i class="fa fa-star star-select" data-value="5"></i>
                                                    <input name="Star" id="StarInput" type="hidden" value="5"/>
                                                </div>
                                            </div>

                                            <div class="alert alert-info py-2 small mb-3">
                                                <i class="fa fa-user-check me-1"></i> Đăng nhập với tư cách: <strong>@User.Identity.Name</strong>
                                            </div>
                                            
                                            <div class="mb-3">
                                                <input asp-for="@Model.Name" class="form-control" placeholder="Họ và tên bạn muốn hiển thị *" required />
                                                <span asp-validation-for="@Model.Name" class="text-danger small"></span>
                                            </div>
                                            
                                            <input asp-for="@Model.Email" type="hidden" value="@User.Identity.Name" />

                                            <div class="mb-3">
                                                <textarea asp-for="@Model.Comment" class="form-control" rows="4" placeholder="Ví dụ: Sản phẩm rất tốt, đúng mô tả..." required></textarea>
                                                <span asp-validation-for="@Model.Comment" class="text-danger small"></span>
                                            </div>

                                            <div class="text-end">
                                                <button type="submit" class="btn btn-brand w-100 py-2 fw-bold">GỬI ĐÁNH GIÁ</button>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning text-center py-4">
                                            <i class="fa fa-exclamation-triangle fa-2x mb-2 d-block"></i>
                                            <p class="mb-0">Bạn cần mua sản phẩm này để có thể để lại đánh giá.</p>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-dark text-center py-4">
                                        <i class="fa fa-lock fa-2x mb-2 d-block"></i>
                                        <p class="mb-2">Vui lòng đăng nhập để đánh giá sản phẩm.</p>
                                        <a href="/Account/Login" class="btn btn-sm btn-brand">Đăng nhập ngay</a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm liên quan (Sử dụng Product Grid chuẩn) -->
        <!-- Sản phẩm liên quan (Sử dụng Slider tương tự Trang chủ) -->
        @if (ViewBag.RelatedProducts != null && (ViewBag.RelatedProducts as IEnumerable<ProductModel>).Any())
        {
            var relatedProducts = ViewBag.RelatedProducts as IEnumerable<ProductModel>;
            <div class="related-section mt-5 border-top pt-4">
                <h2 class="section-title mb-4">SẢN PHẨM LIÊN QUAN</h2>
                
                <div class="position-relative">
                    <div id="related-slider" class="product-slider-container pb-3 px-1">
                        @foreach (var related in relatedProducts)
                        {
                            <div class="product-slider-item">
                                <div class="laptopcenter-card h-100">
                                    <a href="javascript:void(0)" class="laptopcenter-card-wishlist add-to-wishlist" data-product_id="@related.Id" title="Thêm vào yêu thích">
                                        <i class="fa fa-heart"></i>
                                    </a>

                                    <a asp-action="Details" asp-controller="Product" asp-route-Slug="@related.Slug">
                                        <div class="laptopcenter-card-img">
                                            <img src="@related.Image" alt="@related.Name" />
                                        </div>
                                    </a>

                                    <div class="laptopcenter-card-body">
                                        <a asp-action="Details" asp-controller="Product" asp-route-Slug="@related.Slug" class="laptopcenter-card-title">
                                            @related.Name
                                        </a>

                                        <div class="laptopcenter-card-price">
                                            @related.Price.ToString("#,##0 VNĐ")
                                        </div>

                                        <div class="laptopcenter-card-specs">
                                            <span class="laptopcenter-spec-item"><i class="fa fa-building"></i> @related.Brand?.Name</span>
                                            <span class="laptopcenter-spec-item text-success"><i class="fa fa-check-circle"></i> @(string.IsNullOrEmpty(related.Condition) ? "Mới 100%" : related.Condition)</span>
                                        </div>

                                        <div class="laptopcenter-card-actions mt-auto">
                                            @if(related.Quantity > 0)
                                            {
                                                <button class="btn-brand add-to-cart w-100" data-product_id="@related.Id">
                                                    <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn-brand btn-disabled w-100" disabled>
                                                    <i class="fa fa-ban me-1"></i> Hết hàng
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if(relatedProducts.Count() > 4) {
                        <button class="slider-nav-btn slider-prev" type="button" onclick="document.getElementById('related-slider').scrollBy({left: -250, behavior: 'smooth'})">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button class="slider-nav-btn slider-next" type="button" onclick="document.getElementById('related-slider').scrollBy({left: 250, behavior: 'smooth'})">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    }
                </div>
            </div>
        }
        
    </div>
</div>
</div><!-- /container -->

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Star rating picker logic
            $('.star-select').on('click', function() {
                var val = $(this).data('value');
                $('#StarInput').val(val);
                
                // Color the stars
                $('.star-select').each(function() {
                    if($(this).data('value') <= val) {
                        $(this).removeClass('far').addClass('fa');
                    } else {
                        $(this).removeClass('fa').addClass('far');
                    }
                });
            });

            // Hover effect
            $('.star-select').on('mouseover', function() {
                var val = $(this).data('value');
                $('.star-select').each(function() {
                    if($(this).data('value') <= val) {
                        $(this).css('opacity', '0.7');
                    }
                });
            }).on('mouseout', function() {
                $('.star-select').css('opacity', '1');
            });
        });
    </script>
}
