@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductDetails.Name;
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<style>
/* Specific Styles for TechStore Product Details */
.tech-detail-wrap { background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); margin-bottom: 30px; display: flex; flex-wrap: wrap; }
.tech-detail-img { border: 1px solid #eee; border-radius: 8px; padding: 20px; text-align: center; }
.tech-detail-img img { max-width: 100%; height: auto; object-fit: contain; }
.tech-detail-info h1 { font-size: 24px; font-weight: 700; color: #333; margin-top: 0; margin-bottom: 15px; }
.tech-detail-price { font-size: 28px; font-weight: 800; color: #e3001b; margin-bottom: 20px; display: inline-block; }
.tech-detail-specs { background: #f8f9fa; border-radius: 8px; padding: 15px; margin-bottom: 25px; }
.tech-detail-specs p { margin: 0 0 10px 0; font-size: 14px; color: #555; }
.tech-detail-specs p strong { color: #333; display: inline-block; width: 100px; }
.tech-detail-action { display: flex; gap: 15px; align-items: center; margin-bottom: 30px; padding-top: 20px; border-top: 1px dashed #ddd; }
.quantity-input { width: 80px; text-align: center; border: 1px solid #ddd; border-radius: 6px; padding: 10px; font-size: 16px; font-weight: bold; height: 50px; }
.btn-buy-now { flex: 1; background: #e3001b; color: #fff; font-size: 16px; font-weight: bold; text-transform: uppercase; border: none; padding: 13px; border-radius: 6px; transition: background 0.2s; height: 50px; display:flex; align-items:center; justify-content:center; text-decoration: none !important;}
.btn-buy-now:hover, .btn-buy-now:focus { background: #c00015; color: #fff; }
.btn-disabled-large { flex: 1; background: #ccc; color: #666; font-size: 16px; font-weight: bold; text-transform: uppercase; border: none; padding: 13px; border-radius: 6px; cursor: not-allowed; height: 50px; display:flex; align-items:center; justify-content:center; }
.btn-wishlist-large { border: 1px solid #e3001b; color: #e3001b; background: #fff; height: 50px; width: 50px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 20px; transition: all 0.2s; }
.btn-wishlist-large:hover, .btn-wishlist-large.active { background: #e3001b; color: #fff; }

.tech-tabs { margin-top: 40px; }
.tech-tabs .nav-tabs > li > a { border-radius: 0; color: #555; font-weight: 600; text-transform: uppercase; border: none; padding: 15px 25px; }
.tech-tabs .nav-tabs > li.active > a, .tech-tabs .nav-tabs > li.active > a:hover { border: none; border-bottom: 3px solid #e3001b; color: #e3001b; font-weight: bold; }
.tech-tabs .tab-content { background: #fff; padding: 30px; border-radius: 0 0 8px 8px; border: 1px solid #eee; border-top: none; }
.review-form { background: #f9f9f9; padding: 25px; border-radius: 8px; margin-top: 20px; }
.review-form input, .review-form textarea { width: 100%; border: 1px solid #ddd; border-radius: 4px; padding: 10px; margin-bottom: 15px; }
.review-form textarea { height: 100px; resize: vertical; }
.review-form button { background: #333; color: #fff; border: none; padding: 10px 25px; border-radius: 4px; text-transform: uppercase; font-weight: bold; }
.review-form button:hover { background: #e3001b; }
.related-section { margin-top: 50px; }
</style>

<div class="row">
    <!-- Cột Menu Trái (Giữ Sidebar nếu cần thiết) -->
	<div class="col-sm-3 col-md-3">
        @Html.Partial("_SidebarPartial")
	</div>

	<div class="col-sm-9 col-md-9 padding-right">
        
        <!-- Khung hiển thị Chi tiết -->
        <div class="tech-detail-wrap">
            <div class="col-sm-6">
                <div class="tech-detail-img">
                    <img src="~/media/products/@Model.ProductDetails.Image" alt="@Model.ProductDetails.Name" />
                </div>
            </div>
            
            <div class="col-sm-6">
                <div class="tech-detail-info">
                    <h1>@Model.ProductDetails.Name</h1>
                    <div class="tech-detail-price">
                        @Model.ProductDetails.Price.ToString("#,##0 VNĐ")
                    </div>
                    
                    <div class="tech-detail-specs">
                        <p><strong><i class="fa fa-tag"></i> Danh mục:</strong> @Model.ProductDetails.Category?.Name</p>
                        <p><strong><i class="fa fa-building"></i> Thương hiệu:</strong> @Model.ProductDetails.Brand?.Name</p>
                        <p><strong><i class="fa fa-check-circle"></i> Tình trạng:</strong> Hàng mới 100%</p>
                        <p><strong><i class="fa fa-shield-alt"></i> Bảo hành:</strong> 12 Tháng chính hãng</p>
                    </div>

                    <div class="tech-detail-action">
                        @if(Model.ProductDetails.Quantity > 0){
                            <input type="number" class="quantity-input" value="1" min="1" max="@Model.ProductDetails.Quantity" title="Số lượng" />
                            <a class="btn-buy-now add-to-cart" href="javascript:void(0)" data-product_id="@Model.ProductDetails.Id">
                                <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> THÊM VÀO GIỎ
                            </a>
                        }
                        else{
                            <button class="btn-disabled-large" disabled>
                                <i class="fa fa-ban" style="margin-right: 5px;"></i> HẾT HÀNG
                            </button>
                        }
                        <!-- Wishlist button (tận dụng từ techstore.css) -->
                         <a href="javascript:void(0)" class="btn-wishlist-large add-to-wishlist" data-product_id="@Model.ProductDetails.Id" title="Lưu yêu thích">
                            <i class="fa fa-heart"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khối Thông tin Tabs -->
        <div class="tech-tabs">
            <ul class="nav nav-tabs">
                <li class="active"><a href="#details" data-toggle="tab">Mô tả sản phẩm</a></li>
                <li><a href="#reviews" data-toggle="tab">Đánh giá & Bình luận</a></li>
            </ul>
            
            <div class="tab-content">
                <div class="tab-pane fade active in" id="details">
                    <div style="line-height: 1.6; color: #444;">
                        @Html.Raw(Model.ProductDetails.Description)
                    </div>
                </div>

                <div class="tab-pane fade" id="reviews">
                    <p><b>Viết đánh giá của bạn</b></p>
                    <div class="review-form">
                        <form autocomplete="off" asp-action="CommentProduct" asp-controller="Product" method="POST">
                            <input asp-for="@Model.ProductDetails.Id" name="ProductId" type="hidden" />
                            <input name="Star" type="hidden" value="5"/>
                            
                            <div class="row">
                                <div class="col-sm-6">
                                    <input asp-for="@Model.Name" type="text" placeholder="Tên của bạn *" required />
                                    <span asp-validation-for="@Model.Name" class="text-danger"></span>
                                </div>
                                <div class="col-sm-6">
                                    <input asp-for="@Model.Email" type="email" placeholder="Email của bạn (không bắt buộc)" />
                                    <span asp-validation-for="@Model.Email" class="text-danger"></span>
                                </div>
                            </div>

                            <textarea asp-for="@Model.Comment" placeholder="Chia sẻ cảm nhận về sản phẩm..." required></textarea>
                            <span asp-validation-for="@Model.Comment" class="text-danger"></span>

                            <div class="text-right mt-2" style="text-align: right;">
                                <button type="submit">Gửi đánh giá</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm liên quan (Sử dụng Product Grid chuẩn) -->
        @if (ViewBag.RelatedProducts != null && (ViewBag.RelatedProducts as IEnumerable<ProductModel>).Any())
        {
            <div class="related-section">
                <h2 class="section-title">Sản Phẩm Cùng Danh Mục</h2>
                <div class="row">
                    @foreach (var related in @ViewBag.RelatedProducts as IEnumerable<ProductModel>)
                    {
                        <div class="col-sm-6 col-md-4 product-wrapper">
                            <div class="tech-card">
                                <a href="javascript:void(0)" class="tech-card-wishlist add-to-wishlist" data-product_id="@related.Id" title="Thêm vào yêu thích">
                                    <i class="fa fa-heart"></i>
                                </a>

                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@related.Id" class="tech-card-img">
                                    <img src="~/media/products/@related.Image" alt="@related.Name" />
                                </a>

                                <div class="tech-card-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Id="@related.Id" class="tech-card-title">
                                        @related.Name
                                    </a>

                                    <div class="tech-card-price">
                                        @related.Price.ToString("#,##0 VNĐ")
                                    </div>

                                    <div class="tech-card-specs">
                                        <span class="tech-spec-item"><i class="fa fa-tag"></i> @related.Category?.Name</span>
                                        <span class="tech-spec-item"><i class="fa fa-building"></i> @related.Brand?.Name</span>
                                    </div>

                                    <div class="tech-card-actions">
                                        @if(related.Quantity > 0)
                                        {
                                            <button class="btn-brand add-to-cart" data-product_id="@related.Id">
                                                <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> Thêm vào giỏ
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn-brand btn-disabled" disabled>
                                                <i class="fa fa-ban" style="margin-right: 5px;"></i> Hết hàng
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}