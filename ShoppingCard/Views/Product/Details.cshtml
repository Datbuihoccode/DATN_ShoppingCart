@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductDetails.Name;
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}



<div class="container py-4">
<div class="row">
    <!-- Cột Menu Trái (Giữ Sidebar nếu cần thiết) -->
	<div class="col-md-3">
        @Html.Partial("_SidebarPartial")
	</div>

	<div class="col-md-9">
        
        <!-- Khung hiển thị Chi tiết -->
        <div class="tech-detail-wrap row g-0">
            <div class="col-md-6">
                <div class="tech-detail-img p-4">
                    <img src="~/media/products/@Model.ProductDetails.Image" alt="@Model.ProductDetails.Name" class="img-fluid" />
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="tech-detail-info p-4">
                    <h1>@Model.ProductDetails.Name</h1>
                    <div class="tech-detail-price">
                        @Model.ProductDetails.Price.ToString("#,##0 VNĐ")
                    </div>
                    
                    <div class="tech-detail-specs">
                        <p><strong><i class="fa fa-tag"></i> Danh mục:</strong> @Model.ProductDetails.Category?.Name</p>
                        <p><strong><i class="fa fa-building"></i> Thương hiệu:</strong> @Model.ProductDetails.Brand?.Name</p>
                        <p><strong><i class="fa fa-check-circle"></i> Tình trạng:</strong> Hàng mới 100%</p>
                        <p><strong><i class="fa fa-shield-alt"></i> Bảo hành:</strong> 12 Tháng chính hãng</p>
                    </div>

                    <div class="tech-detail-action">
                        @if(Model.ProductDetails.Quantity > 0){
                            <input type="number" class="quantity-input" value="1" min="1" max="@Model.ProductDetails.Quantity" title="Số lượng" />
                            <a class="btn-buy-now add-to-cart" href="javascript:void(0)" data-product_id="@Model.ProductDetails.Id">
                                <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> THÊM VÀO GIỎ
                            </a>
                        }
                        else{
                            <button class="btn-disabled-large" disabled>
                                <i class="fa fa-ban" style="margin-right: 5px;"></i> HẾT HÀNG
                            </button>
                        }
                        <!-- Wishlist button (tận dụng từ techstore.css) -->
                         <a href="javascript:void(0)" class="btn-wishlist-large add-to-wishlist" data-product_id="@Model.ProductDetails.Id" title="Lưu yêu thích">
                            <i class="fa fa-heart"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Khối Thông tin Tabs -->
        <div class="tech-tabs">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details" type="button" role="tab">Mô tả sản phẩm</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">Đánh giá & Bình luận</button>
                </li>
            </ul>
            
            <div class="tab-content">
                <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
                    <div style="line-height: 1.8; color: #555;">
                        @Html.Raw(Model.ProductDetails.Description)
                    </div>
                </div>

                <div class="tab-pane fade" id="reviews" role="tabpanel" aria-labelledby="reviews-tab">
                    <p class="h5 mb-4 fw-bold" style="color: var(--text-main);">Viết đánh giá của bạn</p>
                    <div class="review-form">
                        <form autocomplete="off" asp-action="CommentProduct" asp-controller="Product" method="POST">
                            <input asp-for="@Model.ProductDetails.Id" name="ProductId" type="hidden" />
                            <input name="Star" type="hidden" value="5"/>
                            
                            <div class="row">
                                <div class="col-6">
                                    <input asp-for="@Model.Name" type="text" placeholder="Tên của bạn *" required />
                                    <span asp-validation-for="@Model.Name" class="text-danger"></span>
                                </div>
                                <div class="col-6">
                                    <input asp-for="@Model.Email" type="email" placeholder="Email của bạn (không bắt buộc)" />
                                    <span asp-validation-for="@Model.Email" class="text-danger"></span>
                                </div>
                            </div>

                            <textarea asp-for="@Model.Comment" placeholder="Chia sẻ cảm nhận về sản phẩm..." required></textarea>
                            <span asp-validation-for="@Model.Comment" class="text-danger"></span>

                            <div class="text-end mt-2">
                                <button type="submit" class="btn btn-brand-primary">Gửi đánh giá</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sản phẩm liên quan (Sử dụng Product Grid chuẩn) -->
        @if (ViewBag.RelatedProducts != null && (ViewBag.RelatedProducts as IEnumerable<ProductModel>).Any())
        {
            <div class="related-section">
                <h2 class="section-title">Sản Phẩm Cùng Danh Mục</h2>
                <div class="row g-4">
                    @foreach (var related in @ViewBag.RelatedProducts as IEnumerable<ProductModel>)
                    {
                        <div class="col-6 col-md-4">
                            <div class="tech-card h-100">
                                <a href="javascript:void(0)" class="tech-card-wishlist add-to-wishlist" data-product_id="@related.Id" title="Thêm vào yêu thích">
                                    <i class="fa fa-heart"></i>
                                </a>

                                <a asp-action="Details" asp-controller="Product" asp-route-Slug="@related.Slug">
                                    <div class="tech-card-img">
                                        <img src="~/media/products/@related.Image" alt="@related.Name" />
                                    </div>
                                </a>

                                <div class="tech-card-body">
                                    <a asp-action="Details" asp-controller="Product" asp-route-Slug="@related.Slug" class="tech-card-title">
                                        @related.Name
                                    </a>

                                    <div class="tech-card-price">
                                        @related.Price.ToString("#,##0 VNĐ")
                                    </div>

                                    <div class="tech-card-specs">
                                        <span class="tech-spec-item"><i class="fa fa-tag"></i> @related.Category?.Name</span>
                                        <span class="tech-spec-item"><i class="fa fa-building"></i> @related.Brand?.Name</span>
                                    </div>

                                    <div class="tech-card-actions">
                                        @if(related.Quantity > 0)
                                        {
                                            <button class="btn-brand add-to-cart" data-product_id="@related.Id">
                                                <i class="fa fa-shopping-cart" style="margin-right: 5px;"></i> Thêm vào giỏ
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn-brand btn-disabled" disabled>
                                                <i class="fa fa-ban" style="margin-right: 5px;"></i> Hết hàng
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        
    </div>
</div>
</div><!-- /container -->

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}