@{
    var currentUrl = Url.ActionContext.HttpContext.Request.Path;
    var currentSort = Url.ActionContext.HttpContext.Request.Query["sort_by"].ToString();
}

<div class="filter-bar-wrap">
    <!-- Group: Sort -->
    <div class="filter-group" style="max-width: 400px;">
        <label class="filter-label"><i class="fa fa-sort-amount-down me-1"></i> Sắp xếp theo</label>
        <select id="sort_by" class="lc-select">
            <option value="">Mặc định</option>
            <option value="@currentUrl?sort_by=price_increase" selected="@(currentSort == "price_increase" ? "selected" : null)">Giá: Thấp đến Cao</option>
            <option value="@currentUrl?sort_by=price_decrease" selected="@(currentSort == "price_decrease" ? "selected" : null)">Giá: Cao đến Thấp</option>
            <option value="@currentUrl?sort_by=price_newest" selected="@(currentSort == "price_newest" ? "selected" : null)">Mới nhất</option>
            <option value="@currentUrl?sort_by=price_oldest" selected="@(currentSort == "price_oldest" ? "selected" : null)">Cũ nhất</option>
        </select>
    </div>

    <!-- Action -->
    <div class="filter-action d-none">
        <!-- Hidden button if needed, but removing visible one -->
    </div>
</div>
