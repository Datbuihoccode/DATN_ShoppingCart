<!DOCTYPE html>
<html lang="vi">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>@ViewData["Title"] - TechStore</title>
	<link href="~/css/bootstrap.min.css" rel="stylesheet">
	<!-- Upgrade to FontAwesome 5 -->
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
	<link href="~/css/animate.css" rel="stylesheet">
	<link href="~/css/main.css" rel="stylesheet">
	<link href="~/css/responsive.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.min.css" rel="stylesheet">
	
	<link href="~/css/techstore.css" rel="stylesheet">
</head>
<body>
	<!-- HEADER KHUNG MỚI -->
	<div class="tech-topbar hidden-xs">
		<div class="container">
			<div class="row">
				<div class="col-sm-6">
					<i class="fa fa-phone-alt" style="color: var(--secondary-color);"></i> Hotline tư vấn: <strong style="color: #fff;">1800.1234</strong>
				</div>
				<div class="col-sm-6 text-right">
					<a href="#"><i class="fa fa-map-marker-alt"></i> Hệ thống 125 cửa hàng</a>
					<a href="#"><i class="fa fa-truck"></i> Tra cứu đơn hàng</a>
					<a href="#"><i class="fa fa-shield-alt"></i> Check bảo hành</a>
				</div>
			</div>
		</div>
	</div>

	<header class="tech-header">
		<div class="container header-flex">
			<!-- Logo -->
			<div class="tech-logo">
				<a href="/">TECH<span>STORE</span></a>
			</div>
			
			<!-- Search Bar -->
			<div class="tech-search hidden-xs">
				<form asp-controller="Product" asp-action="Search" method="post">
					<input type="text" name="searchTearm" placeholder="Bạn muốn tìm laptop, điện thoại hay phụ kiện..." required />
					<button type="submit"><i class="fa fa-search"></i> Tìm kiếm</button>
				</form>
			</div>

			<!-- User Actions -->
			<div class="tech-actions">
				<a asp-controller="Home" asp-action="Contact" class="action-item hidden-sm hidden-xs">
					<i class="fa fa-headset"></i>
					<span>Tư vấn</span>
				</a>
				<a asp-controller="Home" asp-action="Wishlist" class="action-item hidden-xs">
					<i class="fa fa-heart"></i>
					<span>Yêu thích</span>
				</a>

                <!-- Account Dropdown Using BS3 structure -->
				<div class="dropdown action-item" style="cursor: pointer;">
                    <a data-toggle="dropdown" class="" style="color: #fff; height: 100%; display: flex; flex-direction: column; align-items: center; background: transparent; border: none; padding: 0;">
						<i class="fa fa-user" style="font-size: 22px; margin-bottom: 5px;"></i>
						<span>@((User.Identity?.IsAuthenticated ?? false) ? "Tài khoản" : "Đăng nhập")</span>
					</a>
					<ul class="dropdown-menu dropdown-menu-right" style="margin-top: 15px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border: none;">
						@if(User.Identity?.IsAuthenticated ?? false)
						{
                            <li style="padding: 10px 20px; font-weight: bold; border-bottom: 1px solid #eee;">Xin chào, @User.Identity.Name!</li>
							<li><a asp-controller="Account" asp-action="History" style="padding: 10px 20px;"><i class="fa fa-list-alt" style="width: 20px;"></i> Đơn hàng</a></li>
							<li><a asp-controller="Account" asp-action="UpdateAccount" style="padding: 10px 20px;"><i class="fa fa-id-card" style="width: 20px;"></i> Hồ sơ</a></li>
							<li><a asp-controller="Admin" asp-action="Index" style="padding: 10px 20px;"><i class="fa fa-cog" style="width: 20px;"></i> Quản trị</a></li>
							<li class="divider"></li>
							<li><a asp-controller="Account" asp-action="Logout" style="padding: 10px 20px; color: #e3001b;"><i class="fa fa-sign-out-alt" style="width: 20px;"></i> Đăng xuất</a></li>
						}
						else
						{
							<li><a asp-controller="Account" asp-action="Login" style="padding: 10px 20px; font-weight: bold;"><i class="fa fa-sign-in-alt" style="width: 20px;"></i> Đăng nhập</a></li>
							<li><a asp-controller="Account" asp-action="Create" style="padding: 10px 20px;"><i class="fa fa-user-plus" style="width: 20px;"></i> Tạo tài khoản mới</a></li>
						}
					</ul>
				</div>

				<a asp-controller="Cart" asp-action="Index" class="action-item" style="position: relative;">
					<i class="fa fa-shopping-cart"></i>
					<span>Giỏ hàng</span>
					<!-- badge có thể được dynamic render bằng viewcomponent -->
					<!-- <span class="cart-badge">0</span> -->
				</a>
			</div>
		</div>
	</header>

	<!-- Main Navigation -->
	<nav class="tech-nav hidden-xs">
		<div class="container">
			<ul>
				<li><a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Trang chủ</a></li>
				<li><a asp-controller="Category" asp-action="Index" asp-route-slug="laptop"><i class="fa fa-laptop"></i> Laptop & Macbook</a></li>
				<li><a asp-controller="Category" asp-action="Index" asp-route-slug="dien-thoai"><i class="fa fa-mobile-alt"></i> Điện thoại di động</a></li>
				<li><a asp-controller="Category" asp-action="Index" asp-route-slug="am-thanh"><i class="fa fa-headphones"></i> Âm thanh & Phụ kiện</a></li>
				<li><a asp-controller="Category" asp-action="Index" asp-route-slug="pc-linh-kien"><i class="fa fa-desktop"></i> PC & Linh kiện</a></li>
				<li><a asp-controller="Blog" asp-action="Index"><i class="fa fa-newspaper"></i> Tin Công Nghệ</a></li>
			</ul>
		</div>
	</nav>

	<!-- NỘI DUNG CHÍNH (Body Render) -->
	<section class="container-main">
		<div class="container">
			<div class="row">
				<partial name="_NotificationPartial" />
				@RenderBody()
			</div>
		</div>
	</section>

	<!-- FOOTER KHUNG MỚI -->
	<footer class="tech-footer">
		<div class="container">
			<div class="row">
				<div class="col-sm-3 col-xs-6">
					<h4>Về TechStore</h4>
					<ul>
						<li><a href="#">Giới thiệu công ty</a></li>
						<li><a href="#">Chính sách bảo mật</a></li>
						<li><a href="#">Quy chế hoạt động</a></li>
						<li><a href="#">Tuyển dụng</a></li>
                        <li><a href="#">Tin tức TechStore</a></li>
					</ul>
				</div>
				<div class="col-sm-3 col-xs-6">
					<h4>Hỗ Trợ Khách Hàng</h4>
					<ul>
						<li><a href="#">Hướng dẫn mua trả góp</a></li>
						<li><a href="#">Hướng dẫn mua trực tuyến</a></li>
						<li><a href="#">Giao hàng & Lắp đặt</a></li>
						<li><a href="#">Chính sách bảo hành</a></li>
                        <li><a href="#">Khách hàng doanh nghiệp (B2B)</a></li>
					</ul>
				</div>
				<div class="col-sm-3 col-xs-6">
					<h4>Tổng đài hỗ trợ</h4>
					<ul>
						<li>Gọi tư vấn: <strong style="color: #fff">1800.1234</strong> (7h30 - 22h00)</li>
						<li>Gọi bảo hành: <strong style="color: #fff">1800.4321</strong> (8h00 - 21h00)</li>
						<li>Kỹ thuật: <strong style="color: #fff">1800.9999</strong> (8h00 - 21h00)</li>
					</ul>
                    <div style="margin-top: 15px; font-size: 20px;">
                        <a href="#" style="color: #4267B2; margin-right: 15px;"><i class="fab fa-facebook-square"></i></a>
                        <a href="#" style="color: #FF0000; margin-right: 15px;"><i class="fab fa-youtube"></i></a>
                        <a href="#" style="color: #E1306C;"><i class="fab fa-instagram"></i></a>
                    </div>
				</div>
				<div class="col-sm-3 col-xs-6">
					<h4>Khác</h4>
					<vc:footer />
				</div>
			</div>
			<div class="footer-bottom-bar">
				<p>&copy; 2026 TechStore Mobile Shopping. Hệ thống bán lẻ thiết bị công nghệ hàng đầu Việt Nam.</p>
			</div>
		</div>
	</footer>

	<script src="~/js/jquery.js"></script>
	<script src="~/js/bootstrap.min.js"></script>
	<script src="~/js/jquery.scrollUp.min.js"></script>
	<script src="~/js/price-range.js"></script>
	<script src="~/js/jquery.prettyPhoto.js"></script>
	<script src="~/js/main.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.all.min.js"></script>
	<script src="~/js/techstore.js"></script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
