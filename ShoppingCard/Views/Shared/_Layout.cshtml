<!DOCTYPE html>
<html lang="vi">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>@ViewData["Title"] - LaptopCenter</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<!-- Upgrade to FontAwesome 5 -->
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
	<link href="~/css/animate.css" rel="stylesheet">
	<link href="~/css/main.css" rel="stylesheet">
	<link href="~/css/responsive.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.min.css" rel="stylesheet">
	
	<link href="~/css/laptopcenter.css" rel="stylesheet">
</head>
<body>
	<!-- HEADER KHUNG MỚI -->

	<header class="laptopcenter-header">
		<div class="container header-flex">
			<!-- Logo -->
			<div class="laptopcenter-logo">
				<a href="/">LAPTOP<span>CENTER</span></a>
			</div>
			
			<!-- Category Menu Component -->
            <div class="header-menu-block">
                @await Component.InvokeAsync("HeaderMenu")
            </div>

			<!-- Search Bar -->
			<div class="laptopcenter-search d-none d-md-block">
				<form asp-controller="Product" asp-action="Search" method="post">
					<input type="text" name="searchTearm" placeholder="Tìm kiếm Laptop Gaming, MacBook, Văn phòng..." required />
					<button type="submit"><i class="fa fa-search"></i> Tìm kiếm</button>
				</form>
			</div>

			<!-- User Actions -->
			<div class="laptopcenter-actions">

				<a asp-controller="Home" asp-action="Wishlist" class="action-item d-none d-md-block">
					<i class="fa fa-heart"></i>
					<span>Yêu thích</span>
				</a>

                <!-- Account Dropdown Using BS3 structure -->
				<div class="dropdown action-item" style="cursor: pointer;">
                    <a data-bs-toggle="dropdown" class="" style="color: #fff; height: 100%; display: flex; flex-direction: column; align-items: center; background: transparent; border: none; padding: 0;">
						<i class="fa fa-user" style="font-size: 22px; margin-bottom: 5px;"></i>
						<span>@((User.Identity?.IsAuthenticated ?? false) ? "Tài khoản" : "Đăng nhập")</span>
					</a>
					<ul class="dropdown-menu dropdown-menu-end" style="margin-top: 15px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border: none;">
						@if(User.Identity?.IsAuthenticated ?? false)
						{
                            <li style="padding: 10px 20px; font-weight: bold; border-bottom: 1px solid #eee;">Xin chào, @User.Identity.Name!</li>
							<li><a asp-controller="Account" asp-action="History" style="padding: 10px 20px;"><i class="fa fa-list-alt" style="width: 20px;"></i> Đơn hàng</a></li>
							<li><a asp-controller="Account" asp-action="UpdateAccount" style="padding: 10px 20px;"><i class="fa fa-id-card" style="width: 20px;"></i> Hồ sơ</a></li>
							<li><a asp-controller="Admin" asp-action="Index" style="padding: 10px 20px;"><i class="fa fa-cog" style="width: 20px;"></i> Quản trị</a></li>
							<li><hr class="dropdown-divider"></li>
							<li><a asp-controller="Account" asp-action="Logout" style="padding: 10px 20px; color: #e3001b;"><i class="fa fa-sign-out-alt" style="width: 20px;"></i> Đăng xuất</a></li>
						}
						else
						{
							<li><a asp-controller="Account" asp-action="Login" style="padding: 10px 20px; font-weight: bold;"><i class="fa fa-sign-in-alt" style="width: 20px;"></i> Đăng nhập</a></li>
							<li><a asp-controller="Account" asp-action="Create" style="padding: 10px 20px;"><i class="fa fa-user-plus" style="width: 20px;"></i> Tạo tài khoản mới</a></li>
						}
					</ul>
				</div>

				<a asp-controller="Cart" asp-action="Index" class="action-item" style="position: relative;">
					<i class="fa fa-shopping-cart"></i>
					<span>Giỏ hàng</span>
					<!-- badge có thể được dynamic render bằng viewcomponent -->
					<!-- <span class="cart-badge">0</span> -->
				</a>
			</div>
		</div>
	</header>

	<!-- Main Navigation -->
	<nav class="laptopcenter-nav d-none d-md-block">
		<div class="container">
			@await Component.InvokeAsync("CategoryNav")
		</div>
	</nav>

	<!-- NỘI DUNG CHÍNH (Body Render) -->
	<section class="container-main">
		@RenderBody()
	</section>

	<!-- FOOTER PREMIUM REFACTOR -->
	<footer class="laptopcenter-footer">
		<div class="container">
			<div class="row">
				<!-- Cột 1: Thương hiệu -->
				<div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
					<a href="/" class="footer-logo">LAPTOP<span>CENTER</span></a>
					<p class="small mb-4" style="line-height: 1.8;">
						Chuyên gia cung cấp các dòng Laptop Gaming, Văn phòng và MacBook chính hãng hàng đầu Việt Nam. Chất lượng và sự hài lòng của bạn là ưu tiên số 1 của chúng tôi.
					</p>
					<div class="d-flex gap-3 fs-5">
						<a href="#" style="color: #1877f2;"><i class="fab fa-facebook"></i></a>
						<a href="#" style="color: #ff0000;"><i class="fab fa-youtube"></i></a>
						<a href="#" style="color: #c32aa3;"><i class="fab fa-instagram"></i></a>
						<a href="#" style="color: #1da1f2;"><i class="fab fa-twitter"></i></a>
					</div>
				</div>

				<!-- Cột 2: Hỗ trợ khách hàng -->
				<div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
					<h4>Hỗ Trợ Khách Hàng</h4>
					<ul>
						<li><a href="#"><i class="fas fa-chevron-right"></i> Hướng dẫn mua hàng</a></li>
						<li><a href="#"><i class="fas fa-chevron-right"></i> Chính sách bảo hành</a></li>
						<li><a href="#"><i class="fas fa-chevron-right"></i> Chính sách đổi trả</a></li>
						<li><a href="#"><i class="fas fa-chevron-right"></i> Trả góp 0% lãi suất</a></li>
						<li><a href="#"><i class="fas fa-chevron-right"></i> Vận chuyển toàn quốc</a></li>
					</ul>
				</div>

				<!-- Cột 3: Liên hệ -->
				<div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
					<h4>Tổng Đài Hỗ Trợ</h4>
					<div class="footer-hotline-item">
						<span>Gọi mua hàng (Miễn phí)</span>
						<strong>1800.1234</strong>
					</div>
					<div class="footer-hotline-item">
						<span>Hỗ trợ kỹ thuật</span>
						<strong>1800.4321</strong>
					</div>
					<div class="footer-hotline-item">
						<span>Email hỗ trợ</span>
						<strong style="font-size: 15px;">contact@laptopcenter.com</strong>
					</div>
				</div>

				<!-- Cột 4: Thanh toán & Đối tác -->
				<div class="col-lg-3 col-md-6">
					<h4>Thanh Toán</h4>
					<p class="small mb-2">Hỗ trợ đa dạng phương thức:</p>
					<div class="payment-methods">
						<div class="payment-item" title="VNPAY"><img src="~/media/payments/vnpay.png" alt="VNPAY"></div>
						<div class="payment-item" title="MoMo"><img src="~/media/payments/momo.png" alt="MOMO"></div>
						<div class="payment-item" title="Thanh toán khi nhận hàng" style="color: #1a1a2e; font-weight: bold; font-size: 11px;">COD</div>
					</div>
					
				</div>
			</div>

			<div class="footer-bottom-bar">
				<p>&copy; 2026 LaptopCenter. Hệ thống bán lẻ Laptop chính hãng toàn quốc.</p>
			</div>
		</div>
	</footer>

	<script src="~/js/jquery.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/jquery.scrollUp.min.js"></script>
	<script src="~/js/price-range.js"></script>
	<script src="~/js/jquery.prettyPhoto.js"></script>
	<script src="~/js/main.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.22/dist/sweetalert2.all.min.js"></script>
	<script src="~/js/laptopcenter.js"></script>

    <script>
        $(function () {
            var msg = '@Html.Raw(TempData["success"])';
            if (msg && msg.trim() !== '') {
                Swal.fire({ icon: 'success', title: 'Thành công!', text: msg, timer: 2500, showConfirmButton: false });
            }
            var err = '@Html.Raw(TempData["error"])';
            if (err && err.trim() !== '') {
                Swal.fire({ icon: 'error', title: 'Lỗi!', text: err });
            }
        });
    </script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
