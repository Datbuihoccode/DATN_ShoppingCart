<div id="slider-carousel" class="carousel slide mb-4" data-bs-ride="carousel">
    <div class="carousel-indicators">
        @{ int totalSliders = (ViewBag.Sliders?.Count ?? 0) + 2; }
        @for (int i = 0; i < totalSliders; i++)
        {
            <button type="button" data-bs-target="#slider-carousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
        }
    </div>

    <div class="carousel-inner">
        <!-- Banners chuyên biệt cho Laptop Store -->
        <div class="carousel-item active">
            <img src="~/media/sliders/banner_gaming.png" class="d-block w-100" alt="Laptop Gaming Banner">
            <div class="carousel-caption d-none d-md-block carousel-caption-custom">
                <h2 class="fw-bold">CHINH PHỤC MỌI TỰA GAME</h2>
                <p>Laptop Gaming cấu hình cực khủng - Trải nghiệm không giới hạn.</p>
                <a href="#" class="btn btn-brand">XEM NGAY</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/media/sliders/banner_office.png" class="d-block w-100" alt="Laptop Office Banner">
            <div class="carousel-caption d-none d-md-block text-start carousel-caption-custom light">
                <h2 class="fw-bold">SANG TRỌNG & ĐẲNG CẤP</h2>
                <p>Dòng Ultrabook mỏng nhẹ, tinh tế cho doanh nhân và văn phòng.</p>
                <a href="#" class="btn btn-brand">KHÁM PHÁ</a>
            </div>
        </div>

        @if (ViewBag.Sliders != null)
        {
            @foreach (var slider in ViewBag.Sliders)
            {
                <div class="carousel-item">
                    <img src="~/media/sliders/@slider.Image" class="d-block w-100" alt="@slider.Name">
                </div>
            }
        }
    </div>

    <button class="carousel-control-prev control-carousel" type="button" data-bs-target="#slider-carousel" data-bs-slide="prev">
        <i class="fa fa-angle-left"></i>
    </button>
    <button class="carousel-control-next control-carousel" type="button" data-bs-target="#slider-carousel" data-bs-slide="next">
        <i class="fa fa-angle-right"></i>
    </button>
</div>
