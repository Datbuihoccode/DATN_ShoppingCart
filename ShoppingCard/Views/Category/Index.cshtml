@model IEnumerable<ProductModel>
<div class="container py-4">
    <div class="row">
        <div class="col-md-3 mb-4">
            @Html.Partial("_SidebarPartial")
        </div>

        <style>
            .product-image-wrapper { height: 220px; overflow: hidden; }
        </style>

        <div class="col-md-9">
            <partial name="_FilterProductPartial" />
            <h2 class="section-title">Sản Phẩm</h2>
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-4">
                        <div class="tech-card h-100">
                            <a href="javascript:void(0)" class="tech-card-wishlist add-to-wishlist" data-product_id="@item.Id">
                                <i class="fa fa-heart"></i>
                            </a>
                            <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id">
                                <div class="tech-card-img">
                                    @{
                                        string labelClass = "label-default";
                                        string catName = item.Category.Name.ToLower();
                                        if(catName.Contains("gaming")) labelClass = "label-gaming";
                                        else if(catName.Contains("văn phòng") || catName.Contains("học tập")) labelClass = "label-office";
                                        else if(catName.Contains("đồ họa") || catName.Contains("workstation")) labelClass = "label-workstation";
                                        else if(catName.Contains("mỏng nhẹ") || catName.Contains("ultrabook")) labelClass = "label-ultrabook";
                                    }
                                    <div class="tech-card-label @labelClass">@item.Category.Name</div>
                                    <img src="~/media/products/@item.Image" alt="@item.Name" />
                                </div>
                            </a>
                            <div class="tech-card-body">
                                <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id" class="tech-card-title">
                                    @item.Name
                                </a>
                                <div class="tech-card-price">@item.Price.ToString("#,##0 VNĐ")</div>
                                <div class="tech-card-specs">
                                    <span class="tech-spec-item"><i class="fa fa-building"></i> @item.Brand.Name</span>
                                    <span class="tech-spec-item text-success"><i class="fa fa-check-circle"></i> New Fullbox</span>
                                </div>
                                <div class="tech-card-actions mt-auto">
                                    @if(item.Quantity > 0)
                                    {
                                        <button class="btn-brand add-to-cart w-100" data-product_id="@item.Id">
                                            <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-brand btn-disabled w-100" disabled>Hết hàng</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#sort_by').on('change', function () {
                var url = $(this).val();
                if (url) { window.location = url; }
                return false;
            });
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            var query = new URLSearchParams(window.location.search);
            var startQuery = parseInt(query.get('startprice'), 10);
            var endQuery = parseInt(query.get('endprice'), 10);
            var startValue = Number.isFinite(startQuery) ? startQuery : 1000000;
            var endValue = Number.isFinite(endQuery) ? endQuery : 30000000;

            $("#slider-range").slider({
                min: 1000000, max: 50000000, step: 100000,
                value: [startValue, endValue],
                tooltip: 'hide', handle: 'round'
            });

            function formatVnd(value) {
                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
            }
            function updateAmount(values) {
                $("#amount").val(formatVnd(values[0]) + " - " + formatVnd(values[1]));
            }

            var sliderInstance = $("#slider-range").data("slider");
            if (!sliderInstance) return;
            updateAmount(sliderInstance.getValue());

            $("#slider-range").on("slide", function (event) { updateAmount(event.value); });

            $('.btn-locgia').on('click', function () {
                var url = $(this).data('current_url');
                if (url) {
                    var vals = sliderInstance.getValue();
                    window.location = url + "?startprice=" + vals[0] + "&endprice=" + vals[1];
                }
                return false;
            });
        });
    </script>
}
