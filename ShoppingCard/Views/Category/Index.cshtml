@using ShoppingCard.Application.DTOs
@model IEnumerable<ProductDto>
@{
    var catName = ViewBag.CategoryName?.ToUpper() ?? "SẢN PHẨM";
}
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <partial name="_FilterProductPartial" />
            <h2 class="section-title">@catName</h2>
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-3">
                        <div class="laptopcenter-card h-100">
                            <a href="javascript:void(0)" class="laptopcenter-card-wishlist add-to-wishlist" data-product_id="@item.Id">
                                <i class="fa fa-heart"></i>
                            </a>
                            <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug">
                                <div class="laptopcenter-card-img">
                                    <img src="@item.Image" alt="@item.Name" />
                                </div>
                            </a>
                            <div class="laptopcenter-card-body">
                                <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug" class="laptopcenter-card-title">
                                    @item.Name
                                </a>
                                <div class="laptopcenter-card-price">@item.Price.ToString("#,##0 đ")</div>
                                <div class="laptopcenter-card-specs">
                                    <span class="laptopcenter-spec-item"><i class="fa fa-building"></i> @item.BrandName</span>
                                    <span class="laptopcenter-spec-item text-success"><i class="fa fa-check-circle"></i> @(string.IsNullOrEmpty(item.Condition) ? "Mới 100%" : item.Condition)</span>
                                </div>
                                <div class="laptopcenter-card-actions mt-auto">
                                    @if(item.Quantity > 0)
                                    {
                                        <button class="btn-brand add-to-cart w-100" data-product_id="@item.Id">
                                            <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-brand btn-disabled w-100" disabled>Hết hàng</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-5">
                    <ul class="pagination justify-content-center">
                        @{
                            var currentUrl = Url.ActionContext.HttpContext.Request.Path;
                            var currentSort = Context.Request.Query["sort_by"].ToString();
                            var currentBrand = Context.Request.Query["brand"].ToString(); 
                            var startPrice = Context.Request.Query["startprice"].ToString();
                            var endPrice = Context.Request.Query["endprice"].ToString();

                            string BuildPageUrl(int pageNum)
                            {
                                var query = new List<string>();
                                if (!string.IsNullOrEmpty(currentSort)) query.Add($"sort_by={currentSort}");
                                if (!string.IsNullOrEmpty(currentBrand)) query.Add($"brand={currentBrand}");
                                if (!string.IsNullOrEmpty(startPrice)) query.Add($"startprice={startPrice}");
                                if (!string.IsNullOrEmpty(endPrice)) query.Add($"endprice={endPrice}");
                                query.Add($"pg={pageNum}");
                                return currentUrl + "?" + string.Join("&", query);
                            }
                        }

                        @if (ViewBag.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(ViewBag.CurrentPage - 1)">
                                    <i class="fa fa-chevron-left me-1" style="font-size: 12px;"></i> Trước
                                </a>
                            </li>
                        }

                        @for (int p = 1; p <= ViewBag.TotalPages; p++)
                        {
                            <li class="page-item @(p == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@BuildPageUrl(p)">@p</a>
                            </li>
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@BuildPageUrl(ViewBag.CurrentPage + 1)">
                                    Sau <i class="fa fa-chevron-right ms-1" style="font-size: 12px;"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        .ready(function () {
            #sort_by.on('change', function () {
                var url = .val();
                if (url) { window.location = url; }
                return false;
            });

            .on('click', '.btn-lc-filter', function () {
                var url = #sort_by.val();
                if (url) {
                    window.location = url;
                }
                return false;
            });
        });
    </script>
}
