@model IEnumerable<ProductModel>
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <partial name="_FilterProductPartial" />
            <h2 class="section-title">Sản Phẩm</h2>
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-3">
                        <div class="laptopcenter-card h-100">
                            <a href="javascript:void(0)" class="laptopcenter-card-wishlist add-to-wishlist" data-product_id="@item.Id">
                                <i class="fa fa-heart"></i>
                            </a>
                            <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug">
                                <div class="laptopcenter-card-img">
                                    @{
                                        string labelClass = "label-default";
                                        string catName = item.Category.Name.ToLower();
                                        if(catName.Contains("gaming")) labelClass = "label-gaming";
                                        else if(catName.Contains("văn phòng") || catName.Contains("học tập")) labelClass = "label-office";
                                        else if(catName.Contains("đồ họa") || catName.Contains("workstation")) labelClass = "label-workstation";
                                        else if(catName.Contains("mỏng nhẹ") || catName.Contains("ultrabook")) labelClass = "label-ultrabook";
                                    }
                                    <div class="laptopcenter-card-label @labelClass">@item.Category.Name</div>
                                    <img src="~/media/products/@item.Image" alt="@item.Name" />
                                </div>
                            </a>
                            <div class="laptopcenter-card-body">
                                <a asp-action="Details" asp-controller="Product" asp-route-Slug="@item.Slug" class="laptopcenter-card-title">
                                    @item.Name
                                </a>
                                <div class="laptopcenter-card-price">@item.Price.ToString("#,##0 VNĐ")</div>
                                <div class="laptopcenter-card-specs">
                                    <span class="laptopcenter-spec-item"><i class="fa fa-building"></i> @item.Brand.Name</span>
                                    <span class="laptopcenter-spec-item text-success"><i class="fa fa-check-circle"></i> New Fullbox</span>
                                </div>
                                <div class="laptopcenter-card-actions mt-auto">
                                    @if(item.Quantity > 0)
                                    {
                                        <button class="btn-brand add-to-cart w-100" data-product_id="@item.Id">
                                            <i class="fa fa-shopping-cart me-1"></i> Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-brand btn-disabled w-100" disabled>Hết hàng</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#sort_by').on('change', function () {
                var url = $(this).val();
                if (url) { window.location = url; }
                return false;
            });

            $(document).on('click', '.btn-lc-filter', function () {
                var url = $('#sort_by').val();
                if (url) {
                    window.location = url;
                }
                return false;
            });
        });
    </script>
}
