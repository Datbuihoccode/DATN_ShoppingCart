@model IEnumerable<OrderDetail>

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var order = ViewBag.Order as Order;
    var details = Model?.ToList() ?? new List<OrderDetail>();
    decimal subtotalAmount = details.Sum(x => x.Price * x.Quantity);
    decimal discountAmount = order?.DiscountAmount ?? 0m;
    decimal shippingFee = order?.ShippingFee ?? 0m;
    if (discountAmount < 0m) { discountAmount = 0m; }
    if (discountAmount > subtotalAmount) { discountAmount = subtotalAmount; }
    decimal totalAmount = subtotalAmount - discountAmount + shippingFee;
}

<div class="container lc-account-container">
    <div class="lc-card">
        <div class="lc-card-header">
            <h3><i class="fa fa-info-circle me-2"></i> CHI TIẾT ĐƠN HÀNG #@order?.OrderCode</h3>
            <a asp-action="History" class="btn btn-outline-dark btn-sm">Quay lại danh sách</a>
        </div>
        <div class="lc-card-body">
            <div class="row mb-5">
                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">Thông tin đơn hàng</h5>
                    <p class="mb-1"><strong>Trạng thái:</strong>
                        @{
                            var voBadge = order?.Status switch
                            {
                                OrderStatus.New => "badge-new",
                                OrderStatus.Cancelled => "badge-cancel",
                                OrderStatus.Completed => "badge-received",
                                _ => "badge-done"
                            };
                            if (order?.PaymentStatus == PaymentStatus.Pending) voBadge = "badge-new";
                            if (order?.PaymentStatus == PaymentStatus.Failed) voBadge = "badge-cancel";
                        }
                        <span class="lc-badge @voBadge">@order?.DisplayStatusForUser</span>
                    </p>
                    <p class="mb-1"><strong>Ngày đặt:</strong> @order?.CreateDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-1"><strong>Phương thức thanh toán:</strong> @order?.PaymentMethod</p>
                    <p class="mb-1"><strong>Dia chi giao hang:</strong> @(string.IsNullOrWhiteSpace(order?.ShippingAddress) ? "-" : order.ShippingAddress)</p>
                    <p class="mb-1"><strong>Coupon:</strong> @(string.IsNullOrWhiteSpace(order?.CouponCode) ? "-" : order.CouponCode)</p>
                    
                    @{
                        var isPending = order?.PaymentStatus == PaymentStatus.Pending;
                        var isExpired = isPending && (order?.CreateDate.AddHours(1) < DateTime.Now);
                        var canCancel = (order?.Status == OrderStatus.New || isPending) && !isExpired && order?.Status != OrderStatus.Cancelled;
                    }

                    @if (canCancel)
                    {
                        <div class="mt-3">
                            @if (isPending)
                            {
                                <a asp-action="RetryPayment" asp-controller="Account"
                                   asp-route-ordercode="@order.OrderCode"
                                   class="btn btn-warning fw-bold">
                                    <i class="fas fa-redo me-1"></i> Thanh toán lại
                                </a>
                            }
                            <a asp-action="CancelOrder" asp-controller="Account"
                               asp-route-ordercode="@order.OrderCode"
                               class="btn btn-outline-danger ms-1"
                               onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?');">
                                Hủy đơn
                            </a>
                        </div>
                    }

                    @if (order?.Status == OrderStatus.Delivered)
                    {
                        <div class="mt-3">
                            <a asp-action="ConfirmReceived" asp-controller="Account"
                               asp-route-ordercode="@order.OrderCode"
                               class="btn btn-success fw-bold"
                               onclick="return confirm('Bạn xác nhận đã nhận được hàng và hài lòng với sản phẩm?');">
                                <i class="fas fa-check me-1"></i> Đã nhận hàng (Xác nhận hoàn tất)
                            </a>
                        </div>
                    }

                    @if (order?.Status == OrderStatus.Completed)
                    {
                        <div class="mt-3">
                            <button type="button" class="btn btn-outline-warning fw-bold" 
                                    data-bs-toggle="modal" data-bs-target="#returnModal-@order.OrderCode">
                                <i class="fas fa-undo me-1"></i> Yêu cầu trả hàng
                            </button>
                        </div>

                        <!-- Return Modal -->
                        <div class="modal fade" id="returnModal-@order.OrderCode" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <form asp-action="RequestReturn" asp-controller="Account" method="post">
                                    <input type="hidden" name="ordercode" value="@order.OrderCode" />
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Yêu cầu trả hàng #@order.OrderCode</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body text-start">
                                            <div class="mb-3">
                                                <label class="form-label">Lý do trả hàng:</label>
                                                <textarea name="note" class="form-control" rows="3" required placeholder="Vui lòng nhập lý do cụ thể..."></textarea>
                                            </div>
                                            <p class="small text-muted">Lưu ý: Yêu cầu trả hàng sẽ được nhân viên xem xét và phản hồi sớm nhất.</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <button type="submit" class="btn btn-warning">Gửi yêu cầu</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
                <div class="col-md-6 text-md-end">
                    <h5 class="fw-bold mb-3">Thông tin khách hàng</h5>
                    <p class="mb-1"><strong>Email:</strong> @order?.UserName</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="lc-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in details)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.Product?.Image ?? string.Empty)" alt="@(item.Product?.Name ?? "Sản phẩm")" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; margin-right: 15px;" />
                                        <span class="fw-bold text-dark">@(item.Product?.Name ?? "Sản phẩm")</span>
                                    </div>
                                </td>
                                <td class="text-center">@item.Price.ToString("#,##0 VND")</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end fw-bold text-brand">@((item.Price * item.Quantity).ToString("#,##0 VND"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end py-2">Tạm tính:</td>
                            <td class="text-end py-2">@subtotalAmount.ToString("#,##0 VND")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end py-2">Giảm giá:</td>
                            <td class="text-end py-2 text-success">-@discountAmount.ToString("#,##0 VND")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end py-2">Phi van chuyen:</td>
                            <td class="text-end py-2">@shippingFee.ToString("#,##0 VND")</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end py-3 fw-bold fs-5">TỔNG THANH TOÁN:</td>
                            <td class="text-end py-3 fw-bold fs-5 text-brand">@totalAmount.ToString("#,##0 VND")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>


