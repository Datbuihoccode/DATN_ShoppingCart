@model AppUserModel
@{
    ViewData["title"] = "Cài đặt mật khẩu mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="tech-card p-4 p-md-5">
                <h2 class="section-title mb-4">Mật khẩu mới</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <form asp-action="UpdateNewPassword" asp-controller="Account" method="post">
                    <input type="hidden" name="token" value="@ViewBag.Token" />

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-muted">Email</label>
                        <input asp-for="Email" value="@ViewBag.Email" readonly class="form-control" style="background: #f0f2f5; cursor: not-allowed; color: #888;" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="PasswordHash" class="form-label text-muted">Mật khẩu mới</label>
                        <input asp-for="PasswordHash" type="password" class="form-control" placeholder="••••••••" required />
                        <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn-brand" style="width:100%; padding: 13px; font-size: 15px; border-radius: 8px;">CẬP NHẬT MẬT KHẨU</button>
                    </div>

                    <div class="text-center border-top pt-3 mt-2">
                        <a asp-action="Login" asp-controller="Account" class="text-muted text-decoration-none small">← Hủy và quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
